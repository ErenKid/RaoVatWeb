@model IEnumerable<RaoVatWeb.Models.Post>

@{
    ViewData["Title"] = "Danh sách tin rao vặt";
}

<div class="container mt-4">
    <h2>Danh sách tin rao vặt</h2>

    <form asp-controller="Posts"
          asp-action="Index"
          method="get"
          class="row g-2 mb-4">

        <div class="col-md-4">
            <input type="text"
                   name="keyword"
                   value="@ViewBag.Keyword"
                   class="form-control"
                   placeholder="Tìm theo tiêu đề hoặc mô tả..." />
        </div>

        <div class="col-md-3">
            <select name="categoryId"
                    asp-items="@(ViewBag.Categories as SelectList)"
                    class="form-select">
                <option value="">-- Tất cả danh mục --</option>
            </select>
        </div>

        <div class="col-md-3">
            <select name="areaId"
                    asp-items="@(ViewBag.Areas as SelectList)"
                    class="form-select">
                <option value="">-- Tất cả khu vực --</option>
            </select>
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">
                Tìm kiếm
            </button>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Chưa có tin rao vặt phù hợp.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            @if (item.IsVipPriority)
                            {
                                <span class="badge bg-danger mb-2">Tin nổi bật</span>
                            }

                            <h5 class="card-title">
                                @item.Title
                            </h5>

                            <p class="card-text text-muted">
                                @(item.Description.Length > 100 
                                    ? item.Description.Substring(0, 100) + "..." 
                                    : item.Description)
                            </p>

                            <p class="mb-1">
                                <strong>Giá:</strong>
                                @string.Format("{0:N0} VNĐ", item.Price)
                            </p>

                            <p class="mb-1">
                                <strong>Danh mục:</strong>
                                @(item.Category != null ? item.Category.Name : "Chưa có")
                            </p>

                            <p class="mb-1">
                                <strong>Khu vực:</strong>
                                @(item.Area != null ? item.Area.Name : "Chưa có")
                            </p>

                            <p class="mb-1">
                                <strong>Lượt xem:</strong>
                                @item.ViewCount
                            </p>

                            <a asp-controller="Posts"
                               asp-action="Details"
                               asp-route-id="@item.PostId"
                               class="btn btn-outline-primary mt-2">
                                Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>