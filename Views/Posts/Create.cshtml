@model RaoVatWeb.ViewModels.PostCreateViewModel

@{
    ViewData["Title"] = "Đăng tin";

    var categories = ViewBag.Categories as List<RaoVatWeb.Models.Category>
        ?? new List<RaoVatWeb.Models.Category>();

    var areas = ViewBag.Areas as List<RaoVatWeb.Models.Area>
        ?? new List<RaoVatWeb.Models.Area>();
}

<style>
    body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    }

    .create-page {
        background: #f4f5f7;
        min-height: 100vh;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        margin-top: -24px;
        padding: 34px 0 52px;
    }

    .create-container {
        max-width: 1320px;
        width: 94vw;
        margin: 0 auto;
    }

    .create-hero {
        background: linear-gradient(135deg, #ffd43b, #f2b705);
        border-radius: 32px;
        padding: 34px 38px;
        margin-bottom: 24px;
        box-shadow: 0 18px 42px rgba(15,23,42,0.12);
        position: relative;
        overflow: hidden;
    }

    .create-hero::after {
        content: "";
        position: absolute;
        right: -60px;
        bottom: -70px;
        width: 250px;
        height: 250px;
        border-radius: 999px;
        background: rgba(255,255,255,0.28);
    }

    .create-hero-content {
        position: relative;
        z-index: 2;
    }

    .create-title {
        font-size: 46px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 8px;
    }

    .create-subtitle {
        color: #374151;
        font-size: 18px;
        line-height: 1.65;
        max-width: 820px;
        margin: 0;
    }

    .create-layout {
        display: grid;
        grid-template-columns: 1.35fr 0.65fr;
        gap: 24px;
        align-items: start;
    }

    .form-card,
    .guide-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 28px;
        padding: 28px;
        box-shadow: 0 12px 30px rgba(15,23,42,0.07);
    }

    .form-section-title {
        font-size: 26px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 6px;
    }

    .form-section-subtitle {
        color: #6b7280;
        font-size: 16px;
        margin-bottom: 24px;
        line-height: 1.55;
    }

    .form-label {
        font-size: 17px;
        font-weight: 750;
        color: #111827;
        margin-bottom: 8px;
    }

    .custom-input,
    .custom-select,
    .custom-textarea {
        border-radius: 17px;
        border: 1px solid #d1d5db;
        background: #f8fafc;
        font-size: 16px;
        font-weight: 600;
        padding: 0 16px;
        width: 100%;
        outline: none;
    }

    .custom-input,
    .custom-select {
        height: 56px;
    }

    .custom-textarea {
        min-height: 170px;
        padding-top: 14px;
        resize: vertical;
        line-height: 1.6;
    }

    .custom-input:focus,
    .custom-select:focus,
    .custom-textarea:focus {
        background: white;
        border-color: #f2b705;
        box-shadow: 0 0 0 0.22rem rgba(255,212,59,0.22);
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
    }

    .upload-box {
        border: 2px dashed #cbd5e1;
        border-radius: 22px;
        background: #f8fafc;
        padding: 24px;
        text-align: center;
        transition: 0.18s ease;
    }

    .upload-box:hover {
        border-color: #facc15;
        background: #fffbea;
    }

    .upload-icon {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        background: #fffbea;
        border: 1px solid #facc15;
        color: #92400e;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        margin-bottom: 12px;
    }

    .upload-title {
        font-size: 18px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 6px;
    }

    .upload-note {
        color: #6b7280;
        font-size: 14px;
        margin-bottom: 14px;
    }

    .file-input {
        max-width: 420px;
        margin: 0 auto;
    }

    .submit-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 24px;
    }

    .btn-submit {
        height: 56px;
        border: none;
        border-radius: 18px;
        background: #111827;
        color: white;
        padding: 0 24px;
        font-size: 17px;
        font-weight: 800;
    }

    .btn-submit:hover {
        background: #000;
    }

    .btn-back {
        height: 56px;
        border-radius: 18px;
        border: 1px solid #d1d5db;
        background: white;
        color: #111827;
        padding: 0 22px;
        font-size: 17px;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
    }

    .btn-back:hover {
        background: #f3f4f6;
        color: #111827;
    }

    .guide-title {
        font-size: 24px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 8px;
    }

    .guide-subtitle {
        color: #6b7280;
        font-size: 15px;
        line-height: 1.55;
        margin-bottom: 18px;
    }

    .guide-list {
        display: grid;
        gap: 12px;
    }

    .guide-item {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 15px;
        display: flex;
        gap: 12px;
        align-items: flex-start;
    }

    .guide-icon {
        width: 30px;
        height: 30px;
        border-radius: 999px;
        background: #ffd43b;
        color: #111827;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .guide-text {
        color: #374151;
        font-size: 15px;
        line-height: 1.55;
        font-weight: 600;
    }

    .vip-note {
        margin-top: 18px;
        background: #fffbea;
        border: 1px solid #facc15;
        color: #92400e;
        border-radius: 18px;
        padding: 15px;
        font-weight: 700;
        line-height: 1.55;
    }

    .text-danger {
        font-size: 14px;
        font-weight: 650;
    }

    .validation-summary-errors {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
        border-radius: 16px;
        padding: 14px 16px;
        margin-bottom: 20px;
        font-weight: 650;
    }

    .validation-summary-errors ul {
        margin-bottom: 0;
        padding-left: 18px;
    }

    @@media (max-width: 1100px) {
        .create-layout {
            grid-template-columns: 1fr;
        }

        .create-title {
            font-size: 38px;
        }
    }

    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .create-hero {
            padding: 28px 24px;
        }

        .create-title {
            font-size: 32px;
        }

        .form-card,
        .guide-card {
            padding: 22px;
        }
    }
</style>

<div class="create-page">
    <div class="create-container">
        <div class="create-hero">
            <div class="create-hero-content">
                <div class="create-title">
                    Đăng tin rao vặt
                </div>

                <p class="create-subtitle">
                    Nhập thông tin sản phẩm, dịch vụ hoặc nhu cầu giao dịch của bạn.
                    Tin sau khi gửi sẽ ở trạng thái chờ duyệt trước khi hiển thị công khai.
                </p>
            </div>
        </div>

        <div class="create-layout">
            <div class="form-card">
                <div class="form-section-title">
                    Thông tin tin đăng
                </div>

                <div class="form-section-subtitle">
                    Vui lòng nhập đầy đủ thông tin để Admin dễ kiểm duyệt và người mua dễ tìm thấy tin của bạn.
                </div>

                <form asp-controller="Posts"
                      asp-action="Create"
                      method="post"
                      enctype="multipart/form-data"
                      asp-antiforgery="true">

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">
                            Tiêu đề tin
                        </label>

                        <input asp-for="Title"
                               class="custom-input"
                               placeholder="Ví dụ: Bán laptop Dell cũ còn bảo hành" />

                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-grid">
                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label">
                                Danh mục
                            </label>

                            <select asp-for="CategoryId" class="custom-select">
                                <option value="">-- Chọn danh mục --</option>

                                @foreach (var category in categories)
                                {
                                    <option value="@category.CategoryId">
                                        @category.Name
                                    </option>
                                }
                            </select>

                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="AreaId" class="form-label">
                                Khu vực
                            </label>

                            <select asp-for="AreaId" class="custom-select">
                                <option value="">-- Chọn khu vực --</option>

                                @foreach (var area in areas)
                                {
                                    <option value="@area.AreaId">
                                        @area.Name
                                    </option>
                                }
                            </select>

                            <span asp-validation-for="AreaId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Price" class="form-label">
                            Giá
                        </label>

                        <input asp-for="Price"
                               class="custom-input"
                               placeholder="Ví dụ: 8500000" />

                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">
                            Mô tả chi tiết
                        </label>

                        <textarea asp-for="Description"
                                  class="custom-textarea"
                                  placeholder="Mô tả tình trạng sản phẩm, thông tin giao dịch, ưu điểm, lưu ý khi liên hệ..."></textarea>

                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            Hình ảnh tin đăng
                        </label>

                        <div class="upload-box">
                            <div class="upload-icon">
                                📷
                            </div>

                            <div class="upload-title">
                                Tải lên hình ảnh
                            </div>

                            <div class="upload-note">
                                Có thể chọn nhiều ảnh. Ảnh đầu tiên sẽ được dùng làm ảnh đại diện nếu hệ thống chưa có ảnh chính.
                            </div>

                            <input type="file"
                                   name="images"
                                   class="form-control file-input"
                                   accept="image/*"
                                   multiple />
                        </div>
                    </div>

                    <div class="submit-row">
                        <button type="submit" class="btn-submit">
                            Gửi tin chờ duyệt
                        </button>

                        <a asp-controller="Posts"
                           asp-action="MyPosts"
                           class="btn-back">
                            Quay lại Tin của tôi
                        </a>
                    </div>
                </form>
            </div>

            <div class="guide-card">
                <div class="guide-title">
                    Lưu ý khi đăng tin
                </div>

                <div class="guide-subtitle">
                    Một tin đăng rõ ràng sẽ giúp người mua dễ hiểu và tăng độ tin cậy.
                </div>

                <div class="guide-list">
                    <div class="guide-item">
                        <div class="guide-icon">1</div>
                        <div class="guide-text">
                            Tiêu đề nên ngắn gọn, có tên sản phẩm hoặc dịch vụ chính.
                        </div>
                    </div>

                    <div class="guide-item">
                        <div class="guide-icon">2</div>
                        <div class="guide-text">
                            Mô tả nên ghi rõ tình trạng, giá, khu vực và cách giao dịch.
                        </div>
                    </div>

                    <div class="guide-item">
                        <div class="guide-icon">3</div>
                        <div class="guide-text">
                            Hình ảnh thật sẽ giúp tin đăng đáng tin hơn và dễ được quan tâm.
                        </div>
                    </div>

                    <div class="guide-item">
                        <div class="guide-icon">4</div>
                        <div class="guide-text">
                            Tin mới đăng sẽ ở trạng thái chờ duyệt. Admin duyệt xong mới hiển thị công khai.
                        </div>
                    </div>
                </div>

                <div class="vip-note">
                    Nếu tài khoản của bạn đang là VIP, tin đăng sẽ được đánh dấu ưu tiên sau khi được Admin duyệt.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}