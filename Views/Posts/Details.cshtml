@model RaoVatWeb.Models.Post

@{
    ViewData["Title"] = "Chi tiết tin rao vặt";
}

<div class="container mt-4">
    <a asp-controller="Posts"
       asp-action="Index"
       class="btn btn-secondary mb-3">
        Quay lại danh sách
    </a>

    <div class="card">
        <div class="card-body">
            @if (Model.IsVipPriority)
            {
                <span class="badge bg-danger mb-2">Tin nổi bật</span>
            }

            <h2>@Model.Title</h2>

            <p class="text-muted">
                Ngày đăng: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                |
                Lượt xem: @Model.ViewCount
            </p>

            <hr />

            @if (Model.Images != null && Model.Images.Count > 0)
            {
                <div class="row mb-3">
                    @foreach (var image in Model.Images)
                    {
                        <div class="col-md-4 mb-3">
                            <img src="@image.ImageUrl"
                                 class="img-fluid rounded border"
                                 style="height: 250px; width: 100%; object-fit: cover;"
                                 alt="@Model.Title" />
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-light">
                    Tin này chưa có hình ảnh.
                </div>
            }

            <p>
                <strong>Giá:</strong>
                @string.Format("{0:N0} VNĐ", Model.Price)
            </p>

            <p>
                <strong>Danh mục:</strong>
                @(Model.Category != null ? Model.Category.Name : "Chưa có")
            </p>

            <p>
                <strong>Khu vực:</strong>
                @(Model.Area != null ? Model.Area.Name : "Chưa có")
            </p>

            <hr />

            <h5>Mô tả chi tiết</h5>
            <p>@Model.Description</p>

            <hr />

            <h5>Thông tin liên hệ</h5>

            <p>
                <strong>Người liên hệ:</strong>
                @Model.ContactName
            </p>

            <p>
                <strong>Số điện thoại:</strong>
                @Model.ContactPhone
            </p>
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">
                        @TempData["Error"]
                    </div>
                }

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <form asp-controller="Chats"
                        asp-action="Start"
                        method="post"
                        class="mt-3">

                        @Html.AntiForgeryToken()

                        <input type="hidden" name="postId" value="@Model.PostId" />

                        <button type="submit" class="btn btn-success">
                            Nhắn tin với người đăng
                        </button>
                    </form>
                }
                else
                {
                    <div class="alert alert-info mt-3">
                        Bạn cần đăng nhập để nhắn tin với người đăng.
                    </div>
                }
            <hr />

            <h5>Gửi liên hệ cho người đăng tin</h5>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }

            <form asp-controller="Posts"
                  asp-action="SendContact"
                  method="post">

                @Html.AntiForgeryToken()

                <input type="hidden" name="postId" value="@Model.PostId" />
            </form>
        </div>
    </div>
</div>