@using System.Security.Claims
@model RaoVatWeb.Models.Post

@{
    ViewData["Title"] = "Chi tiết tin rao";

    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);

    var isOwner = User.Identity != null
                  && User.Identity.IsAuthenticated
                  && Model.UserId == currentUserId;

    var reviews = ViewBag.Reviews as List<RaoVatWeb.Models.Review>
        ?? new List<RaoVatWeb.Models.Review>();

    double averageRating = ViewBag.AverageRating != null
        ? Convert.ToDouble(ViewBag.AverageRating)
        : 0;

    int reviewCount = ViewBag.ReviewCount != null
        ? Convert.ToInt32(ViewBag.ReviewCount)
        : 0;

    bool hasReviewed = ViewBag.HasReviewed == true;

    var mainImage = Model.Images != null
        ? Model.Images.OrderByDescending(x => x.IsMainImage)
            .ThenBy(x => x.PostImageId)
            .FirstOrDefault()
        : null;
}

<style>
    body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    }

    .detail-page {
        background: #f4f5f7;
        min-height: 100vh;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        margin-top: -24px;
        padding: 34px 0 52px;
    }

    .detail-container {
        max-width: 1320px;
        width: 94vw;
        margin: 0 auto;
    }

    .detail-layout {
        display: grid;
        grid-template-columns: 1.35fr 0.65fr;
        gap: 24px;
        align-items: start;
    }

    .detail-card,
    .seller-card,
    .review-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 28px;
        box-shadow: 0 12px 30px rgba(15,23,42,0.07);
        overflow: hidden;
    }

    .image-main-wrap {
        background: #f3f4f6;
        height: 480px;
        position: relative;
        overflow: hidden;
    }

    .main-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .no-image {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #9ca3af;
        font-size: 18px;
        font-weight: 800;
    }

    .vip-badge {
        position: absolute;
        top: 18px;
        left: 18px;
        background: #ef4444;
        color: white;
        border-radius: 999px;
        padding: 8px 14px;
        font-size: 14px;
        font-weight: 800;
        box-shadow: 0 8px 20px rgba(239,68,68,0.28);
    }

    .thumb-row {
        display: flex;
        gap: 12px;
        padding: 16px;
        overflow-x: auto;
        border-bottom: 1px solid #f1f5f9;
    }

    .thumb-img {
        width: 96px;
        height: 76px;
        object-fit: cover;
        border-radius: 16px;
        border: 1px solid #e5e7eb;
        flex-shrink: 0;
    }

    .detail-body {
        padding: 28px;
    }

    .detail-title {
        font-size: 38px;
        line-height: 1.25;
        font-weight: 800;
        color: #111827;
        margin-bottom: 12px;
    }

    .detail-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        color: #6b7280;
        font-size: 15px;
        font-weight: 600;
        margin-bottom: 18px;
    }

    .detail-price {
        color: #ef4444;
        font-size: 36px;
        font-weight: 800;
        margin-bottom: 22px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
        margin-bottom: 24px;
    }

    .info-box {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 16px;
    }

    .info-label {
        color: #6b7280;
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .info-value {
        color: #111827;
        font-size: 17px;
        font-weight: 800;
    }

    .section-title {
        font-size: 26px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 12px;
    }

    .description-text {
        color: #374151;
        font-size: 17px;
        line-height: 1.75;
        white-space: pre-line;
    }

    .seller-card {
        padding: 24px;
        position: sticky;
        top: 86px;
    }

    .seller-avatar {
        width: 76px;
        height: 76px;
        border-radius: 24px;
        background: #111827;
        color: #ffd43b;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        font-weight: 800;
        margin-bottom: 16px;
    }

    .seller-name {
        font-size: 24px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 5px;
    }

    .seller-note {
        color: #6b7280;
        font-size: 15px;
        margin-bottom: 18px;
        line-height: 1.5;
    }

    .contact-box {
        background: #fffbea;
        border: 1px solid #facc15;
        border-radius: 18px;
        padding: 16px;
        margin-bottom: 16px;
    }

    .contact-label {
        color: #92400e;
        font-size: 14px;
        font-weight: 750;
        margin-bottom: 5px;
    }

    .contact-value {
        color: #111827;
        font-size: 22px;
        font-weight: 800;
    }

    .seller-action {
        width: 100%;
        height: 52px;
        border-radius: 17px;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 16px;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .btn-call {
        background: #ffd43b;
        color: #111827;
        border: 1px solid #f2b705;
    }

    .btn-call:hover {
        background: #facc15;
        color: #111827;
    }

    .btn-chat,
    .btn-owner {
        background: #111827;
        color: white;
    }

    .btn-chat:hover,
    .btn-owner:hover {
        background: #000;
        color: white;
    }

    .btn-light-action {
        background: #f3f4f6;
        color: #111827;
        border: 1px solid #e5e7eb;
    }

    .btn-light-action:hover {
        background: #e5e7eb;
        color: #111827;
    }

    .safe-note {
        margin-top: 16px;
        color: #6b7280;
        font-size: 14px;
        line-height: 1.55;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 14px;
    }

    .review-card {
        margin-top: 24px;
        padding: 26px;
    }

    .review-header {
        display: grid;
        grid-template-columns: 1fr 170px;
        gap: 18px;
        align-items: center;
        margin-bottom: 22px;
    }

    .review-title {
        font-size: 28px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 6px;
    }

    .review-subtitle {
        color: #6b7280;
        font-size: 16px;
        line-height: 1.55;
    }

    .score-box {
        background: linear-gradient(135deg, #fffbea, #fff7ed);
        border: 1px solid #facc15;
        border-radius: 22px;
        padding: 18px;
        text-align: center;
    }

    .score-label {
        color: #92400e;
        font-size: 14px;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .score-number {
        color: #111827;
        font-size: 36px;
        font-weight: 800;
        line-height: 1;
    }

    .review-note {
        background: #fffbea;
        border: 1px solid #facc15;
        color: #92400e;
        border-radius: 18px;
        padding: 15px;
        font-weight: 700;
        line-height: 1.6;
        margin-bottom: 18px;
    }

    .review-form-box {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 22px;
        padding: 20px;
        margin-bottom: 22px;
    }

    .rating-widget {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 16px;
        margin-bottom: 16px;
    }

    .rating-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }

    .rating-label {
        color: #111827;
        font-size: 17px;
        font-weight: 800;
    }

    .rating-pill {
        background: #fffbea;
        border: 1px solid #facc15;
        color: #92400e;
        border-radius: 999px;
        padding: 6px 12px;
        font-size: 14px;
        font-weight: 800;
    }

    .star-list {
        display: flex;
        gap: 9px;
        margin-bottom: 10px;
    }

    .rating-star {
        font-size: 44px;
        line-height: 1;
        cursor: pointer;
        color: #d1d5db;
        transition: 0.15s ease;
        user-select: none;
    }

    .rating-star:hover {
        transform: translateY(-2px) scale(1.08);
    }

    .rating-star.active {
        color: #f59e0b;
        text-shadow: 0 4px 12px rgba(245,158,11,0.28);
    }

    .rating-message {
        color: #6b7280;
        font-size: 15px;
        font-weight: 650;
    }

    .rating-message strong {
        color: #111827;
    }

    .rating-error {
        display: none;
        margin-top: 10px;
        background: #fee2e2;
        border: 1px solid #fecaca;
        color: #991b1b;
        border-radius: 14px;
        padding: 10px 12px;
        font-size: 14px;
        font-weight: 750;
    }

    .review-textarea {
        width: 100%;
        min-height: 120px;
        border: 1px solid #d1d5db;
        border-radius: 18px;
        padding: 14px;
        resize: vertical;
        outline: none;
        background: white;
        font-size: 16px;
        font-weight: 600;
        line-height: 1.6;
    }

    .review-textarea:focus {
        border-color: #f2b705;
        box-shadow: 0 0 0 0.22rem rgba(255,212,59,0.22);
    }

    .review-submit {
        height: 52px;
        border: none;
        border-radius: 17px;
        background: #111827;
        color: white;
        padding: 0 22px;
        font-size: 16px;
        font-weight: 800;
    }

    .review-submit:hover {
        background: #000;
    }

    .review-list {
        display: grid;
        gap: 14px;
    }

    .review-item {
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 18px;
        background: #fff;
    }

    .review-user {
        color: #111827;
        font-size: 17px;
        font-weight: 800;
        margin-bottom: 4px;
    }

    .review-date {
        color: #6b7280;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .review-stars {
        color: #f59e0b;
        font-size: 20px;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

    .review-comment {
        color: #374151;
        font-size: 15px;
        line-height: 1.65;
        white-space: pre-line;
    }

    .review-empty {
        background: #f9fafb;
        border: 1px dashed #cbd5e1;
        border-radius: 20px;
        padding: 28px;
        text-align: center;
        color: #6b7280;
        font-size: 16px;
        font-weight: 750;
    }

    .report-box {
        margin-top: 12px;
    }

    .report-toggle {
        color: #ef4444;
        font-size: 13px;
        font-weight: 800;
        cursor: pointer;
    }

    .report-form {
        margin-top: 10px;
        background: #fff7ed;
        border: 1px solid #fed7aa;
        border-radius: 16px;
        padding: 12px;
    }

    .report-textarea {
        width: 100%;
        border-radius: 12px;
        border: 1px solid #d1d5db;
        padding: 10px;
        font-size: 14px;
        resize: vertical;
    }

    .report-btn {
        margin-top: 8px;
        background: #ef4444;
        color: white;
        border: none;
        border-radius: 12px;
        padding: 8px 13px;
        font-size: 13px;
        font-weight: 800;
    }

    .top-back {
        margin-bottom: 18px;
    }

    @@media (max-width: 1100px) {
        .detail-layout {
            grid-template-columns: 1fr;
        }

        .seller-card {
            position: static;
        }

        .detail-title {
            font-size: 32px;
        }
    }

    @@media (max-width: 768px) {
        .image-main-wrap {
            height: 330px;
        }

        .info-grid,
        .review-header {
            grid-template-columns: 1fr;
        }

        .detail-body,
        .review-card,
        .seller-card {
            padding: 22px;
        }

        .detail-price {
            font-size: 30px;
        }

        .rating-star {
            font-size: 38px;
        }
    }
</style>

<div class="detail-page">
    <div class="detail-container">
        <div class="top-back">
            <a asp-controller="Posts"
               asp-action="Index"
               class="btn btn-outline-dark rounded-pill px-4 fw-bold">
                ← Quay lại danh sách
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success rounded-4">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger rounded-4">
                @TempData["Error"]
            </div>
        }

        <div class="detail-layout">
            <div>
                <div class="detail-card">
                    <div class="image-main-wrap">
                        @if (mainImage != null && !string.IsNullOrWhiteSpace(mainImage.ImageUrl))
                        {
                            <img src="@mainImage.ImageUrl"
                                 class="main-image"
                                 alt="@Model.Title" />
                        }
                        else
                        {
                            <div class="no-image">
                                Chưa có hình ảnh
                            </div>
                        }

                        @if (Model.IsVipPriority)
                        {
                            <div class="vip-badge">
                                VIP nổi bật
                            </div>
                        }
                    </div>

                    @if (Model.Images != null && Model.Images.Any())
                    {
                        <div class="thumb-row">
                            @foreach (var image in Model.Images)
                            {
                                <img src="@image.ImageUrl"
                                     class="thumb-img"
                                     alt="@Model.Title" />
                            }
                        </div>
                    }

                    <div class="detail-body">
                        <div class="detail-title">
                            @Model.Title
                        </div>

                        <div class="detail-meta">
                            <span>🕒 @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                            <span>👁 @Model.ViewCount lượt xem</span>
                        </div>

                        <div class="detail-price">
                            @Model.Price.ToString("N0") đ
                        </div>

                        <div class="info-grid">
                            <div class="info-box">
                                <div class="info-label">Danh mục</div>
                                <div class="info-value">
                                    @(Model.Category != null ? Model.Category.Name : "Chưa có danh mục")
                                </div>
                            </div>

                            <div class="info-box">
                                <div class="info-label">Khu vực</div>
                                <div class="info-value">
                                    @(Model.Area != null ? Model.Area.Name : "Chưa có khu vực")
                                </div>
                            </div>
                        </div>

                        <hr />

                        <div class="section-title">
                            Mô tả chi tiết
                        </div>

                        <div class="description-text">
                            @Model.Description
                        </div>
                    </div>
                </div>

                <div class="review-card">
                    <div class="review-header">
                        <div>
                            <div class="review-title">
                                Đánh giá tin đăng
                            </div>

                            <div class="review-subtitle">
                                Người dùng có thể đánh giá chất lượng tin đăng và người đăng tin.
                                Hiện có <strong>@reviewCount</strong> đánh giá.
                            </div>
                        </div>

                        <div class="score-box">
                            <div class="score-label">
                                Điểm trung bình
                            </div>

                            <div class="score-number">
                                @averageRating.ToString("0.0")/5
                            </div>
                        </div>
                    </div>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        if (isOwner)
                        {
                            <div class="review-note">
                                Đây là tin đăng của bạn nên bạn không thể tự đánh giá tin này.
                                Nếu thấy bình luận không phù hợp, bạn có thể báo cáo để Admin xử lý.
                            </div>
                        }
                        else
                        {
                            if (hasReviewed)
                            {
                                <div class="review-note">
                                    Bạn đã đánh giá tin này. Nếu gửi lại, hệ thống sẽ cập nhật đánh giá cũ của bạn.
                                </div>
                            }

                            <div class="review-form-box">
                                <form asp-controller="Reviews"
                                      asp-action="Create"
                                      method="post"
                                      asp-antiforgery="true"
                                      id="reviewForm">

                                    <input type="hidden"
                                           name="postId"
                                           value="@Model.PostId" />

                                    <input type="hidden"
                                           name="rating"
                                           id="ratingValue"
                                           value="0" />

                                    <div class="rating-widget">
                                        <div class="rating-top">
                                            <div class="rating-label">
                                                Chọn mức đánh giá
                                            </div>

                                            <div class="rating-pill" id="ratingPill">
                                                Chưa chọn
                                            </div>
                                        </div>

                                        <div class="star-list">
                                            <span class="rating-star" data-value="1">★</span>
                                            <span class="rating-star" data-value="2">★</span>
                                            <span class="rating-star" data-value="3">★</span>
                                            <span class="rating-star" data-value="4">★</span>
                                            <span class="rating-star" data-value="5">★</span>
                                        </div>

                                        <div class="rating-message" id="ratingText">
                                            Bấm vào số sao để đánh giá mức độ hài lòng của bạn.
                                        </div>

                                        <div class="rating-error" id="ratingError">
                                            Vui lòng chọn số sao trước khi gửi đánh giá.
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold">
                                            Nhận xét
                                        </label>

                                        <textarea name="comment"
                                                  class="review-textarea"
                                                  placeholder="Nhập nhận xét của bạn về tin đăng hoặc người đăng..."
                                                  required></textarea>
                                    </div>

                                    <button type="submit" class="review-submit">
                                        Gửi đánh giá
                                    </button>
                                </form>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="review-note">
                            Vui lòng đăng nhập để đánh giá tin đăng này.
                        </div>
                    }

                    @if (!reviews.Any())
                    {
                        <div class="review-empty">
                            Tin đăng này chưa có đánh giá nào.
                        </div>
                    }
                    else
                    {
                        <div class="review-list">
                            @foreach (var review in reviews)
                            {
                                <div class="review-item">
                                    <div class="review-user">
                                        @(review.User != null && !string.IsNullOrWhiteSpace(review.User.FullName)
                                            ? review.User.FullName
                                            : "Người dùng")
                                    </div>

                                    <div class="review-date">
                                        @review.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                    </div>

                                    <div class="review-stars">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= review.Rating)
                                            {
                                                <span>★</span>
                                            }
                                            else
                                            {
                                                <span>☆</span>
                                            }
                                        }
                                    </div>

                                    <div class="review-comment">
                                        @review.Comment
                                    </div>

                                    @if (User.Identity != null
                                         && User.Identity.IsAuthenticated
                                         && review.UserId != currentUserId)
                                    {
                                        <div class="report-box">
                                            <details>
                                                <summary class="report-toggle">
                                                    Báo cáo đánh giá này
                                                </summary>

                                                <form asp-controller="ReviewReports"
                                                      asp-action="Create"
                                                      method="post"
                                                      asp-antiforgery="true"
                                                      class="report-form">

                                                    <input type="hidden"
                                                           name="reviewId"
                                                           value="@review.ReviewId" />

                                                    <textarea name="reason"
                                                              rows="3"
                                                              class="report-textarea"
                                                              placeholder="Nhập lý do báo cáo: phản cảm, sai sự thật, spam..."
                                                              required></textarea>

                                                    <button type="submit"
                                                            class="report-btn"
                                                            onclick="return confirm('Gửi báo cáo đánh giá này đến Admin?');">
                                                        Gửi báo cáo
                                                    </button>
                                                </form>
                                            </details>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="seller-card">
                <div class="seller-avatar">
                    @(string.IsNullOrWhiteSpace(Model.ContactName)
                        ? "RV"
                        : Model.ContactName.Substring(0, 1).ToUpper())
                </div>

                <div class="seller-name">
                    @(string.IsNullOrWhiteSpace(Model.ContactName)
                        ? "Người đăng tin"
                        : Model.ContactName)
                </div>

                <div class="seller-note">
                    Người đăng tin trên hệ thống RaoVatWeb.
                </div>

                <div class="contact-box">
                    <div class="contact-label">
                        Số điện thoại liên hệ
                    </div>

                    <div class="contact-value">
                        @(string.IsNullOrWhiteSpace(Model.ContactPhone)
                            ? "Chưa cập nhật"
                            : Model.ContactPhone)
                    </div>
                </div>

                @if (isOwner)
                {
                    <a asp-controller="Posts"
                       asp-action="Edit"
                       asp-route-id="@Model.PostId"
                       class="seller-action btn-owner">
                        Sửa tin
                    </a>

                    <a asp-controller="Posts"
                       asp-action="MyPosts"
                       class="seller-action btn-light-action">
                        Quay lại Tin của tôi
                    </a>
                }
                else
                {
                    @if (!string.IsNullOrWhiteSpace(Model.ContactPhone))
                    {
                        <a href="tel:@Model.ContactPhone"
                           class="seller-action btn-call">
                            Gọi người bán
                        </a>
                    }

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <form asp-controller="Chats"
                              asp-action="Start"
                              asp-route-postId="@Model.PostId"
                              method="post"
                              asp-antiforgery="true">

                            <button type="submit"
                                    class="seller-action btn-chat">
                                Nhắn tin
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account"
                           asp-action="Login"
                           class="seller-action btn-chat">
                            Đăng nhập để nhắn tin
                        </a>
                    }
                }

                <div class="safe-note">
                    Khi giao dịch, người mua nên kiểm tra kỹ thông tin sản phẩm,
                    trao đổi rõ với người bán và hạn chế chuyển tiền trước khi xác minh.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const stars = document.querySelectorAll(".rating-star");
        const ratingValue = document.getElementById("ratingValue");
        const ratingText = document.getElementById("ratingText");
        const ratingPill = document.getElementById("ratingPill");
        const ratingError = document.getElementById("ratingError");
        const reviewForm = document.getElementById("reviewForm");

        let selectedRating = 0;

        const ratingLabels = {
            1: "1 sao - Kém",
            2: "2 sao - Chưa tốt",
            3: "3 sao - Bình thường",
            4: "4 sao - Tốt",
            5: "5 sao - Rất tốt"
        };

        function paintStars(value) {
            stars.forEach(star => {
                const starValue = parseInt(star.getAttribute("data-value"));

                if (starValue <= value) {
                    star.classList.add("active");
                } else {
                    star.classList.remove("active");
                }
            });
        }

        if (stars.length > 0 && ratingValue && ratingText && ratingPill) {
            stars.forEach(star => {
                star.addEventListener("mouseenter", function () {
                    const value = parseInt(this.getAttribute("data-value"));
                    paintStars(value);
                });

                star.addEventListener("mouseleave", function () {
                    paintStars(selectedRating);
                });

                star.addEventListener("click", function () {
                    selectedRating = parseInt(this.getAttribute("data-value"));

                    ratingValue.value = selectedRating;
                    ratingText.innerHTML = "Bạn đang chọn <strong>" + ratingLabels[selectedRating] + "</strong>.";
                    ratingPill.textContent = selectedRating + "/5";

                    if (ratingError) {
                        ratingError.style.display = "none";
                    }

                    paintStars(selectedRating);
                });
            });
        }

        if (reviewForm) {
            reviewForm.addEventListener("submit", function (e) {
                if (!ratingValue || ratingValue.value === "0") {
                    e.preventDefault();

                    if (ratingError) {
                        ratingError.style.display = "block";
                    }

                    paintStars(0);
                }
            });
        }
    </script>
}