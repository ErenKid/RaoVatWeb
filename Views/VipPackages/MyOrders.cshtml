@using RaoVatWeb.Models.Enums
@model IEnumerable<RaoVatWeb.Models.VipOrder>

@{
    ViewData["Title"] = "Lịch sử VIP";

    var orders = Model != null
        ? Model.ToList()
        : new List<RaoVatWeb.Models.VipOrder>();

    var paidCount = orders.Count(x => x.Status == VipOrderStatus.Paid);
    var pendingCount = orders.Count(x => x.Status == VipOrderStatus.Pending);
    var totalAmount = orders
        .Where(x => x.Status == VipOrderStatus.Paid)
        .Sum(x => x.Amount);
}

<style>
    body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    }

    .orders-page {
        background: #f4f5f7;
        min-height: 100vh;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        margin-top: -24px;
        padding: 36px 0 56px;
    }

    .orders-container {
        max-width: 1280px;
        width: 94vw;
        margin: 0 auto;
    }

    .orders-hero {
        background: linear-gradient(135deg, #111827, #020617);
        color: white;
        border-radius: 34px;
        padding: 38px;
        margin-bottom: 24px;
        box-shadow: 0 22px 52px rgba(15,23,42,0.18);
        position: relative;
        overflow: hidden;
    }

    .orders-hero::after {
        content: "";
        position: absolute;
        right: -80px;
        bottom: -100px;
        width: 300px;
        height: 300px;
        border-radius: 999px;
        background: rgba(255,212,59,0.18);
    }

    .orders-hero-content {
        position: relative;
        z-index: 2;
        display: flex;
        justify-content: space-between;
        gap: 22px;
        align-items: center;
    }

    .orders-badge {
        display: inline-flex;
        background: rgba(255,212,59,0.14);
        border: 1px solid rgba(255,212,59,0.38);
        color: #ffd43b;
        border-radius: 999px;
        padding: 9px 15px;
        font-weight: 900;
        margin-bottom: 14px;
    }

    .orders-title {
        font-size: 44px;
        font-weight: 900;
        line-height: 1.15;
        margin-bottom: 10px;
    }

    .orders-subtitle {
        color: #d1d5db;
        font-size: 18px;
        line-height: 1.65;
        max-width: 760px;
        margin: 0;
    }

    .buy-more-btn {
        height: 54px;
        border-radius: 18px;
        background: #ffd43b;
        color: #111827;
        border: 1px solid #f2b705;
        padding: 0 22px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 16px;
        font-weight: 900;
        white-space: nowrap;
    }

    .buy-more-btn:hover {
        background: #facc15;
        color: #111827;
    }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .stat-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        padding: 20px;
        box-shadow: 0 12px 30px rgba(15,23,42,0.07);
    }

    .stat-label {
        color: #6b7280;
        font-size: 15px;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .stat-value {
        color: #111827;
        font-size: 32px;
        font-weight: 900;
        line-height: 1.2;
    }

    .orders-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 30px;
        padding: 26px;
        box-shadow: 0 14px 34px rgba(15,23,42,0.08);
    }

    .card-head {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-end;
        margin-bottom: 22px;
    }

    .card-title {
        color: #111827;
        font-size: 30px;
        font-weight: 900;
        margin-bottom: 6px;
    }

    .card-subtitle {
        color: #6b7280;
        font-size: 16px;
        line-height: 1.55;
    }

    .order-count {
        background: #fffbea;
        border: 1px solid #facc15;
        color: #92400e;
        border-radius: 999px;
        padding: 9px 15px;
        font-size: 14px;
        font-weight: 900;
        white-space: nowrap;
    }

    .order-list {
        display: grid;
        gap: 16px;
    }

    .order-item {
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        padding: 20px;
        background: #fff;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 20px;
        transition: 0.18s ease;
    }

    .order-item:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 34px rgba(15,23,42,0.09);
    }

    .order-top {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 12px;
    }

    .order-code {
        background: #111827;
        color: #ffd43b;
        border-radius: 999px;
        padding: 7px 12px;
        font-size: 13px;
        font-weight: 900;
    }

    .status-badge {
        border-radius: 999px;
        padding: 7px 12px;
        font-size: 13px;
        font-weight: 900;
        border: 1px solid transparent;
    }

    .status-paid {
        background: #ecfdf5;
        color: #047857;
        border-color: #a7f3d0;
    }

    .status-pending {
        background: #fff7ed;
        color: #9a3412;
        border-color: #fed7aa;
    }

    .status-cancelled {
        background: #fef2f2;
        color: #b91c1c;
        border-color: #fecaca;
    }

    .package-name {
        color: #111827;
        font-size: 24px;
        font-weight: 900;
        margin-bottom: 8px;
        line-height: 1.3;
    }

    .order-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        color: #6b7280;
        font-size: 15px;
        font-weight: 650;
        line-height: 1.5;
    }

    .order-price-box {
        min-width: 210px;
        background: #fffbea;
        border: 1px solid #facc15;
        border-radius: 22px;
        padding: 18px;
        text-align: right;
    }

    .price-label {
        color: #92400e;
        font-size: 14px;
        font-weight: 850;
        margin-bottom: 6px;
    }

    .price-value {
        color: #ef4444;
        font-size: 27px;
        font-weight: 900;
        line-height: 1.1;
    }

    .empty-box {
        background: #f9fafb;
        border: 1px dashed #cbd5e1;
        border-radius: 24px;
        padding: 46px 24px;
        text-align: center;
        color: #6b7280;
        font-size: 17px;
        font-weight: 700;
    }

    .empty-box strong {
        display: block;
        color: #111827;
        font-size: 24px;
        margin-bottom: 8px;
    }

    .empty-box a {
        margin-top: 18px;
        display: inline-flex;
        height: 52px;
        align-items: center;
        justify-content: center;
        background: #111827;
        color: white;
        border-radius: 17px;
        padding: 0 20px;
        text-decoration: none;
        font-weight: 900;
    }

    .empty-box a:hover {
        background: #000;
        color: white;
    }

    @@media (max-width: 1050px) {
        .stat-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .orders-hero-content {
            flex-direction: column;
            align-items: flex-start;
        }

        .order-item {
            grid-template-columns: 1fr;
        }

        .order-price-box {
            text-align: left;
            min-width: unset;
        }
    }

    @@media (max-width: 640px) {
        .stat-grid {
            grid-template-columns: 1fr;
        }

        .orders-title {
            font-size: 33px;
        }

        .orders-hero,
        .orders-card {
            padding: 22px;
        }

        .card-head {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<div class="orders-page">
    <div class="orders-container">
        <div class="orders-hero">
            <div class="orders-hero-content">
                <div>
                    <div class="orders-badge">
                        👑 Lịch sử thành viên VIP
                    </div>

                    <div class="orders-title">
                        Quản lý các gói VIP đã mua
                    </div>

                    <p class="orders-subtitle">
                        Theo dõi đơn VIP, trạng thái thanh toán, thời gian kích hoạt và ngày hết hạn gói VIP của bạn.
                    </p>
                </div>

                <a asp-controller="VipPackages"
                   asp-action="Index"
                   class="buy-more-btn">
                    Mua thêm gói VIP
                </a>
            </div>
        </div>

        <div class="stat-grid">
            <div class="stat-card">
                <div class="stat-label">Tổng đơn VIP</div>
                <div class="stat-value">@orders.Count</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Đã thanh toán</div>
                <div class="stat-value">@paidCount</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Chờ thanh toán</div>
                <div class="stat-value">@pendingCount</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Tổng đã chi</div>
                <div class="stat-value">@totalAmount.ToString("N0") đ</div>
            </div>
        </div>

        <div class="orders-card">
            <div class="card-head">
                <div>
                    <div class="card-title">
                        Danh sách đơn VIP
                    </div>

                    <div class="card-subtitle">
                        Các đơn mới nhất được hiển thị ở phía trên.
                    </div>
                </div>

                <div class="order-count">
                    @orders.Count đơn
                </div>
            </div>

            @if (!orders.Any())
            {
                <div class="empty-box">
                    <strong>Bạn chưa mua gói VIP nào.</strong>
                    Gói VIP giúp tin đăng nổi bật và được ưu tiên hiển thị hơn.
                    <br />

                    <a asp-controller="VipPackages"
                       asp-action="Index">
                        Xem gói VIP
                    </a>
                </div>
            }
            else
            {
                <div class="order-list">
                    @foreach (var order in orders)
                    {
                        var statusClass = "status-pending";
                        var statusText = "Chờ thanh toán";

                        if (order.Status == VipOrderStatus.Paid)
                        {
                            statusClass = "status-paid";
                            statusText = "Đã thanh toán";
                        }
                        else if (order.Status == VipOrderStatus.Cancelled)
                        {
                            statusClass = "status-cancelled";
                            statusText = "Đã hủy";
                        }

                        var packageName = order.VipPackage != null
                            ? order.VipPackage.Name
                            : "Gói VIP";

                        var duration = order.VipPackage != null
                            ? order.VipPackage.DurationDays.ToString()
                            : "0";

                        var orderCode = "VIP" + order.VipOrderId.ToString("000000");

                        <div class="order-item">
                            <div>
                                <div class="order-top">
                                    <span class="order-code">
                                        @orderCode
                                    </span>

                                    <span class="status-badge @statusClass">
                                        @statusText
                                    </span>
                                </div>

                                <div class="package-name">
                                    @packageName
                                </div>

                                <div class="order-meta">
                                    <span>🕒 Tạo lúc: @order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                    <span>⏳ Thời hạn: @duration ngày</span>

                                    @if (order.PaidAt.HasValue)
                                    {
                                        <span>💳 Thanh toán: @order.PaidAt.Value.ToString("dd/MM/yyyy HH:mm")</span>
                                    }

                                    @if (order.VipExpiredAt.HasValue)
                                    {
                                        <span>👑 Hết hạn VIP: @order.VipExpiredAt.Value.ToString("dd/MM/yyyy")</span>
                                    }
                                </div>
                            </div>

                            <div class="order-price-box">
                                <div class="price-label">
                                    Số tiền
                                </div>

                                <div class="price-value">
                                    @order.Amount.ToString("N0") đ
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>