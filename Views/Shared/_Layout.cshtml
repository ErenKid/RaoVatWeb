@using Microsoft.AspNetCore.Identity
@using RaoVatWeb.Models

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - RaoVatWeb</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <style>
        body {
            background: #f5f6f8;
            font-family: Arial, Helvetica, sans-serif;
            color: #111827;
        }

        .rv-navbar {
            background: #ffd43b;
            border-bottom: 1px solid #f2b705;
            box-shadow: 0 4px 18px rgba(0,0,0,0.08);
        }

        .rv-brand {
            font-weight: 950;
            color: #111827 !important;
            font-size: 22px;
            letter-spacing: -0.3px;
        }

        .rv-brand-badge {
            display: inline-flex;
            width: 34px;
            height: 34px;
            border-radius: 12px;
            background: #111827;
            color: #ffd43b;
            align-items: center;
            justify-content: center;
            font-weight: 950;
            margin-right: 8px;
        }

        .rv-nav-link {
            color: #111827 !important;
            font-weight: 750;
            border-radius: 999px;
            padding: 9px 13px !important;
            margin: 0 2px;
        }

        .rv-nav-link:hover {
            background: rgba(255,255,255,0.65);
        }

        .rv-post-btn {
            background: #111827;
            color: white !important;
            border-radius: 999px;
            padding: 9px 16px !important;
            font-weight: 900;
        }

        .rv-post-btn:hover {
            background: #000;
            color: white !important;
        }

        .rv-account-btn {
            background: #111827;
            color: #ffd43b !important;
            border: 1px solid rgba(17, 24, 39, 0.2);
            border-radius: 999px;
            padding: 9px 15px;
            font-weight: 900;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.12);
        }

        .rv-account-btn:hover,
        .rv-account-btn:focus {
            background: #000;
            color: #ffd43b !important;
        }

        .rv-account-menu {
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            padding: 10px;
            min-width: 285px;
            box-shadow: 0 18px 38px rgba(15, 23, 42, 0.16);
        }

        .rv-dropdown-title {
            padding: 10px 12px 8px;
            border-bottom: 1px solid #e5e7eb;
            margin-bottom: 8px;
        }

        .rv-dropdown-title strong {
            display: block;
            color: #111827;
            font-size: 15px;
            font-weight: 950;
            word-break: break-word;
        }

        .rv-dropdown-title span {
            color: #6b7280;
            font-size: 13px;
            font-weight: 650;
        }

        .rv-dropdown-section {
            color: #6b7280;
            font-size: 12px;
            font-weight: 900;
            padding: 8px 12px 5px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .rv-dropdown-item {
            border-radius: 12px;
            padding: 10px 12px;
            color: #111827;
            font-weight: 800;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 9px;
            width: 100%;
            border: none;
            background: transparent;
            text-align: left;
        }

        .rv-dropdown-item:hover {
            background: #fffbea;
            color: #111827;
        }

        .rv-dropdown-post {
            background: #111827;
            color: white;
            margin-bottom: 8px;
        }

        .rv-dropdown-post:hover {
            background: #000;
            color: white;
        }

        .rv-dropdown-logout {
            color: #b91c1c;
        }

        .rv-dropdown-logout:hover {
            background: #fef2f2;
            color: #b91c1c;
        }

        .rv-main {
            min-height: calc(100vh - 130px);
            padding-top: 24px;
            padding-bottom: 40px;
        }

        .rv-footer {
            background: #111827;
            color: #d1d5db;
            padding: 22px 0;
            font-size: 14px;
        }

        .rv-footer strong {
            color: #ffd43b;
        }

        @@media (max-width: 991.98px) {
            .rv-nav-link,
            .rv-post-btn {
                margin-top: 6px;
                display: inline-block;
            }

            .rv-account-btn {
                width: 100%;
                justify-content: center;
                margin-top: 8px;
            }

            .rv-account-menu {
                width: 100%;
            }
        }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg rv-navbar">
            <div class="container">
                <a class="navbar-brand rv-brand"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">
                    <span class="rv-brand-badge">RV</span>
                    RaoVatWeb
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link rv-nav-link"
                                   asp-area=""
                                   asp-controller="Home"
                                   asp-action="Index">
                                    Trang chủ
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link rv-nav-link"
                                   asp-area="Admin"
                                   asp-controller="Dashboard"
                                   asp-action="Index">
                                    Dashboard
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link rv-nav-link"
                                   asp-area=""
                                   asp-controller="Home"
                                   asp-action="Index">
                                    Trang chủ
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link rv-nav-link"
                                   asp-area=""
                                   asp-controller="Posts"
                                   asp-action="Index">
                                    Tin rao
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link rv-nav-link"
                                   asp-area=""
                                   asp-controller="VipPackages"
                                   asp-action="Index">
                                    Gói VIP
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <button class="btn rv-account-btn dropdown-toggle"
                                        type="button"
                                        id="accountDropdown"
                                        data-bs-toggle="dropdown"
                                        aria-expanded="false">
                                    👤 Tài khoản
                                </button>

                                <ul class="dropdown-menu dropdown-menu-end rv-account-menu"
                                    aria-labelledby="accountDropdown">

                                    <li>
                                        <div class="rv-dropdown-title">
                                            <strong>@User.Identity.Name</strong>

                                            @if (User.IsInRole("Admin"))
                                            {
                                                <span>Quản trị viên</span>
                                            }
                                            else
                                            {
                                                <span>Thành viên</span>
                                            }
                                        </div>
                                    </li>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <div class="rv-dropdown-section">
                                                Quản trị hệ thống
                                            </div>
                                        </li>

                                        <li>
                                            <a class="rv-dropdown-item"
                                               asp-area="Admin"
                                               asp-controller="Dashboard"
                                               asp-action="Index">
                                                📊 Dashboard
                                            </a>
                                        </li>

                                        <li>
                                            <a class="rv-dropdown-item"
                                               asp-area="Admin"
                                               asp-controller="Posts"
                                               asp-action="Index">
                                                ✅ Duyệt tin
                                            </a>
                                        </li>

                                        <li>
                                            <a class="rv-dropdown-item"
                                               asp-area="Admin"
                                               asp-controller="Users"
                                               asp-action="Index">
                                                👥 Người dùng
                                            </a>
                                        </li>

                                        <li>
                                            <a class="rv-dropdown-item"
                                               asp-area="Admin"
                                               asp-controller="Categories"
                                               asp-action="Index">
                                                📂 Danh mục
                                            </a>
                                        </li>

                                        <li>
                                            <a class="rv-dropdown-item"
                                               asp-area="Admin"
                                               asp-controller="Areas"
                                               asp-action="Index">
                                                📍 Khu vực
                                            </a>
                                        </li>

                                        <li>
                                            <a class="rv-dropdown-item"
                                               asp-area="Admin"
                                               asp-controller="VipPackages"
                                               asp-action="Index">
                                                👑 Quản lý gói VIP
                                            </a>
                                        </li>

                                        <li>
                                            <a class="rv-dropdown-item"
                                               asp-area="Admin"
                                               asp-controller="VipOrders"
                                               asp-action="Index">
                                                🧾 Đơn VIP
                                            </a>
                                        </li>

                                        <li>
                                            <hr class="dropdown-divider" />
                                        </li>

                                        <li>
                                            <a class="rv-dropdown-item"
                                               asp-area=""
                                               asp-controller="Profile"
                                               asp-action="Index">
                                                👤 Tài khoản của tôi
                                            </a>
                                        </li>
                                    }
                                    else
                                    {
                                        <li>
                                            <a class="rv-dropdown-item rv-dropdown-post"
                                               asp-area=""
                                               asp-controller="Posts"
                                               asp-action="Create">
                                                ➕ Đăng tin mới
                                            </a>
                                        </li>

                                        <li>
                                            <div class="rv-dropdown-section">
                                                Quản lý cá nhân
                                            </div>
                                        </li>

                                        <li>
                                            <a class="rv-dropdown-item"
                                               asp-area=""
                                               asp-controller="Posts"
                                               asp-action="MyPosts">
                                                📢 Tin của tôi
                                            </a>
                                        </li>

                                        <li>
                                            <a class="rv-dropdown-item"
                                               asp-area=""
                                               asp-controller="Chats"
                                               asp-action="Index">
                                                💬 Tin nhắn
                                            </a>
                                        </li>

                                        <li>
                                            <a class="rv-dropdown-item"
                                               asp-area=""
                                               asp-controller="VipPackages"
                                               asp-action="MyOrders">
                                                👑 Lịch sử VIP
                                            </a>
                                        </li>

                                        <li>
                                            <a class="rv-dropdown-item"
                                               asp-area=""
                                               asp-controller="Profile"
                                               asp-action="Index">
                                                👤 Tài khoản của tôi
                                            </a>
                                        </li>
                                    }

                                    <li>
                                        <hr class="dropdown-divider" />
                                    </li>

                                    <li>
                                        <form asp-area=""
                                              asp-controller="Account"
                                              asp-action="Logout"
                                              method="post">

                                            <button type="submit"
                                                    class="rv-dropdown-item rv-dropdown-logout">
                                                🚪 Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link rv-nav-link"
                                   asp-area=""
                                   asp-controller="Account"
                                   asp-action="Login">
                                    Đăng nhập
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link rv-post-btn"
                                   asp-area=""
                                   asp-controller="Account"
                                   asp-action="Register">
                                    Đăng ký
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="rv-main">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="rv-footer">
        <div class="container d-flex justify-content-between flex-wrap gap-2">
            <div>
                <strong>RaoVatWeb</strong> - Hệ thống mua bán/rao vặt trực tuyến
            </div>

            <div>
                ASP.NET Core MVC + MySQL
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>