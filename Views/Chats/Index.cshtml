@model IEnumerable<RaoVatWeb.ViewModels.ChatInboxItemViewModel>

@{
    ViewData["Title"] = "Tin nhắn";

    var conversations = Model != null
        ? Model.OrderByDescending(x => x.UpdatedAt).ToList()
        : new List<RaoVatWeb.ViewModels.ChatInboxItemViewModel>();
}

<style>
    .chat-page {
        background: #f4f5f7;
        min-height: 100vh;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        margin-top: -24px;
        padding: 34px 0 56px;
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    }

    .chat-container {
        max-width: 1280px;
        width: 94vw;
        margin: 0 auto;
    }

    .chat-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 20px;
        margin-bottom: 24px;
    }

    .page-title {
        color: #111827;
        font-size: 42px;
        font-weight: 950;
        margin-bottom: 8px;
        letter-spacing: -0.8px;
    }

    .page-subtitle {
        color: #6b7280;
        font-size: 17px;
        font-weight: 650;
        margin: 0;
    }

    .back-btn {
        height: 48px;
        border-radius: 16px;
        background: #111827;
        color: white;
        padding: 0 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 15px;
        font-weight: 900;
        white-space: nowrap;
    }

    .back-btn:hover {
        background: #000;
        color: white;
    }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .stat-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        padding: 22px;
        box-shadow: 0 12px 30px rgba(15,23,42,0.07);
    }

    .stat-icon {
        width: 46px;
        height: 46px;
        border-radius: 17px;
        background: #111827;
        color: #ffd43b;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        margin-bottom: 12px;
    }

    .stat-label {
        color: #6b7280;
        font-size: 15px;
        font-weight: 800;
        margin-bottom: 6px;
    }

    .stat-value {
        color: #111827;
        font-size: 32px;
        font-weight: 950;
        line-height: 1;
    }

    .chat-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 30px;
        padding: 26px;
        box-shadow: 0 18px 42px rgba(15,23,42,0.08);
    }

    .tool-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 22px;
    }

    .search-box {
        height: 52px;
        border-radius: 17px;
        border: 1px solid #d1d5db;
        background: #f8fafc;
        padding: 0 16px;
        color: #111827;
        font-size: 15px;
        font-weight: 700;
        width: 420px;
        max-width: 100%;
        outline: none;
    }

    .search-box:focus {
        background: white;
        border-color: #f2b705;
        box-shadow: 0 0 0 0.22rem rgba(255,212,59,0.22);
    }

    .count-pill {
        background: #fffbea;
        border: 1px solid #facc15;
        color: #92400e;
        border-radius: 999px;
        padding: 9px 15px;
        font-size: 14px;
        font-weight: 900;
        white-space: nowrap;
    }

    .conversation-list {
        display: grid;
        gap: 16px;
    }

    .conversation-item {
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        background: #fff;
        padding: 18px;
        display: grid;
        grid-template-columns: 76px 1fr 230px 150px;
        gap: 18px;
        align-items: center;
        transition: 0.18s ease;
    }

    .conversation-item:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 34px rgba(15,23,42,0.09);
        border-color: #facc15;
    }

    .post-thumb {
        width: 76px;
        height: 76px;
        border-radius: 24px;
        background: linear-gradient(135deg, #ffd43b, #fffbea);
        color: #111827;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 31px;
        border: 1px solid #facc15;
    }

    .conversation-main {
        min-width: 0;
    }

    .post-title {
        color: #111827;
        font-size: 21px;
        line-height: 1.3;
        font-weight: 950;
        margin-bottom: 8px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .partner-row {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 8px;
    }

    .avatar {
        width: 34px;
        height: 34px;
        border-radius: 999px;
        background: #111827;
        color: #ffd43b;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 950;
        flex-shrink: 0;
    }

    .partner-name {
        color: #374151;
        font-size: 15px;
        font-weight: 850;
    }

    .type-badge {
        background: #ecfdf5;
        color: #047857;
        border: 1px solid #a7f3d0;
        border-radius: 999px;
        padding: 5px 9px;
        font-size: 12px;
        font-weight: 900;
    }

    .last-message {
        color: #6b7280;
        font-size: 14px;
        font-weight: 650;
        line-height: 1.5;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .time-box {
        text-align: left;
    }

    .time-label {
        color: #6b7280;
        font-size: 13px;
        font-weight: 800;
        margin-bottom: 6px;
    }

    .time-value {
        color: #111827;
        font-size: 15px;
        font-weight: 900;
        margin-bottom: 8px;
    }

    .new-dot {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #2563eb;
        font-size: 13px;
        font-weight: 900;
    }

    .new-dot::before {
        content: "";
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: #2563eb;
    }

    .open-chat-btn {
        height: 46px;
        border-radius: 16px;
        background: #2563eb;
        color: white;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 18px;
        font-size: 15px;
        font-weight: 950;
        box-shadow: 0 10px 20px rgba(37,99,235,0.22);
    }

    .open-chat-btn:hover {
        background: #1d4ed8;
        color: white;
    }

    .empty-box {
        background: #f9fafb;
        border: 1px dashed #cbd5e1;
        border-radius: 24px;
        padding: 56px 24px;
        text-align: center;
        color: #6b7280;
        font-size: 17px;
        font-weight: 750;
    }

    .empty-icon {
        width: 76px;
        height: 76px;
        border-radius: 26px;
        background: #111827;
        color: #ffd43b;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 34px;
        margin: 0 auto 18px;
    }

    .empty-box strong {
        color: #111827;
        font-size: 24px;
        display: block;
        margin-bottom: 8px;
    }

    @@media (max-width: 1050px) {
        .conversation-item {
            grid-template-columns: 76px 1fr;
        }

        .time-box,
        .open-chat-btn {
            grid-column: 1 / -1;
        }

        .open-chat-btn {
            width: 100%;
        }

        .stat-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 640px) {
        .chat-header,
        .tool-row {
            flex-direction: column;
            align-items: flex-start;
        }

        .stat-grid {
            grid-template-columns: 1fr;
        }

        .conversation-item {
            grid-template-columns: 1fr;
        }

        .post-thumb {
            width: 100%;
            height: 90px;
        }

        .page-title {
            font-size: 34px;
        }

        .chat-card {
            padding: 20px;
        }
    }
</style>

<div class="chat-page">
    <div class="chat-container">
        <div class="chat-header">
            <div>
                <div class="page-title">
                    Tin nhắn
                </div>

                <p class="page-subtitle">
                    Quản lý các cuộc trò chuyện liên quan đến tin đăng.
                </p>
            </div>

            <a asp-controller="Home"
               asp-action="Index"
               class="back-btn">
                ← Trang chủ
            </a>
        </div>

        <div class="stat-grid">
            <div class="stat-card">
                <div class="stat-icon">💬</div>
                <div class="stat-label">Tổng cuộc trò chuyện</div>
                <div class="stat-value">@conversations.Count</div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">📢</div>
                <div class="stat-label">Liên quan tin rao</div>
                <div class="stat-value">@conversations.Count</div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">🕒</div>
                <div class="stat-label">Mới nhất</div>
                <div class="stat-value">
                    @(conversations.Any() ? conversations.First().UpdatedAt.ToString("dd/MM") : "0")
                </div>
            </div>
        </div>

        <div class="chat-card">
            <div class="tool-row">
                <input type="text"
                       class="search-box"
                       id="chatSearch"
                       placeholder="Tìm theo tin rao hoặc người trò chuyện..." />

                <div class="count-pill">
                    @conversations.Count cuộc trò chuyện
                </div>
            </div>

            @if (!conversations.Any())
            {
                <div class="empty-box">
                    <div class="empty-icon">💬</div>
                    <strong>Chưa có tin nhắn nào.</strong>
                    Khi bạn nhắn tin với người đăng hoặc có người nhắn cho tin của bạn, cuộc trò chuyện sẽ hiển thị tại đây.
                </div>
            }
            else
            {
                <div class="conversation-list" id="conversationList">
                    @foreach (var item in conversations)
                    {
                        var otherUserName = !string.IsNullOrWhiteSpace(item.OtherUserName)
                            ? item.OtherUserName
                            : "Người dùng";

                        var avatarText = otherUserName.Substring(0, 1).ToUpper();

                        var lastMessage = !string.IsNullOrWhiteSpace(item.LastMessage)
                            ? item.LastMessage
                            : "Chưa có tin nhắn";

                        <div class="conversation-item"
                             data-search="@($"{item.PostTitle} {otherUserName} {lastMessage}".ToLower())">

                            <div class="post-thumb">
                                🛒
                            </div>

                            <div class="conversation-main">
                                <div class="post-title">
                                    @item.PostTitle
                                </div>

                                <div class="partner-row">
                                    <span class="avatar">@avatarText</span>
                                    <span class="partner-name">@otherUserName</span>
                                    <span class="type-badge">Tin thường</span>
                                </div>

                                <div class="last-message">
                                    @lastMessage
                                </div>
                            </div>

                            <div class="time-box">
                                <div class="time-label">
                                    Cập nhật
                                </div>

                                <div class="time-value">
                                    @item.UpdatedAt.ToString("dd/MM/yyyy HH:mm")
                                </div>

                                <div class="new-dot">
                                    Mới
                                </div>
                            </div>

                            <a asp-controller="Chats"
                               asp-action="Details"
                               asp-route-id="@item.ConversationId"
                               class="open-chat-btn">
                                Mở chat
                            </a>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById("chatSearch");
        const rows = document.querySelectorAll(".conversation-item");

        if (searchInput) {
            searchInput.addEventListener("input", function () {
                const keyword = this.value.toLowerCase().trim();

                rows.forEach(row => {
                    const text = row.getAttribute("data-search") || "";
                    row.style.display = text.includes(keyword) ? "grid" : "none";
                });
            });
        }
    </script>
}