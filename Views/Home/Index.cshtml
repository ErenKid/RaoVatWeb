

@model RaoVatWeb.ViewModels.HomeIndexViewModel

@{

    ViewData["Title"] = "Trang chủ";
}

<style>
    body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    }

    .home-page {
        background: #f4f5f7;
        min-height: 100vh;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        margin-top: -24px;
        padding-bottom: 46px;
    }

    .home-hero {
        background:
            radial-gradient(circle at 12% 18%, rgba(255,255,255,0.38), transparent 22%),
            radial-gradient(circle at 88% 18%, rgba(255,255,255,0.28), transparent 20%),
            linear-gradient(135deg, #ffd43b, #f2b705);
        min-height: 300px;
        padding: 46px 0 86px;
        position: relative;
        overflow: hidden;
        border-bottom: 1px solid #eab308;
    }

    .home-hero::before {
        content: "";
        position: absolute;
        left: 6%;
        top: 46px;
        width: 110px;
        height: 110px;
        border-radius: 30px;
        background: rgba(255,255,255,0.22);
        transform: rotate(18deg);
    }

    .home-hero::after {
        content: "";
        position: absolute;
        right: 7%;
        top: 38px;
        width: 145px;
        height: 145px;
        border-radius: 36px;
        background: rgba(255,255,255,0.24);
        transform: rotate(-16deg);
    }

    .home-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 22px;
        position: relative;
        z-index: 2;
    }

    .hero-content {
        text-align: center;
        max-width: 860px;
        margin: 0 auto;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(255,255,255,0.62);
        border: 1px solid rgba(255,255,255,0.82);
        border-radius: 999px;
        padding: 9px 16px;
        font-size: 15px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 18px;
    }

    .hero-badge span {
        width: 30px;
        height: 30px;
        border-radius: 11px;
        background: #111827;
        color: #ffd43b;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
    }

    .hero-title {
        font-size: 48px;
        line-height: 1.15;
        font-weight: 800;
        color: #111827;
        margin-bottom: 14px;
        letter-spacing: -0.4px;
    }

    .hero-subtitle {
        color: #374151;
        font-size: 19px;
        line-height: 1.7;
        margin: 0 auto;
        max-width: 760px;
        font-weight: 500;
    }

    .search-panel {
        max-width: 1120px;
        margin: -52px auto 24px;
        padding: 0 22px;
        position: relative;
        z-index: 5;
    }

    .search-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 28px;
        padding: 20px;
        box-shadow: 0 18px 42px rgba(15,23,42,0.16);
    }

    .search-grid {
        display: grid;
        grid-template-columns: 1.55fr 1fr 1fr 140px;
        gap: 12px;
        align-items: center;
    }

    .home-search-input,
    .home-search-select {
        height: 56px;
        border-radius: 17px;
        border: 1px solid #d1d5db;
        background: #f8fafc;
        color: #111827;
        font-size: 16px;
        font-weight: 600;
        padding: 0 16px;
        width: 100%;
        outline: none;
    }

    .home-search-input:focus,
    .home-search-select:focus {
        background: #fff;
        border-color: #f2b705;
        box-shadow: 0 0 0 0.22rem rgba(255,212,59,0.22);
    }

    .home-search-btn {
        height: 56px;
        border: none;
        border-radius: 17px;
        background: #111827;
        color: #fff;
        font-size: 17px;
        font-weight: 800;
        transition: 0.18s ease;
    }

    .home-search-btn:hover {
        background: #000;
        transform: translateY(-1px);
    }

    .quick-section,
    .content-section {
        max-width: 1280px;
        margin: 0 auto 22px;
        padding: 0 22px;
    }

    .quick-card,
    .section-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 26px;
        padding: 22px;
        box-shadow: 0 10px 28px rgba(15,23,42,0.06);
    }

    .vip-section {
        border: 2px solid #fde68a;
        background: linear-gradient(180deg, #fffdf2, #ffffff);
    }

    .category-grid {
        display: grid;
        grid-template-columns: repeat(8, 1fr);
        gap: 12px;
    }

    .category-item {
        text-decoration: none;
        color: #111827;
        border-radius: 20px;
        background: #fffbea;
        border: 1px solid #fde68a;
        min-height: 112px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 14px 10px;
        transition: 0.18s ease;
    }

    .category-item:hover {
        background: #fef3c7;
        color: #111827;
        transform: translateY(-3px);
        box-shadow: 0 12px 22px rgba(15,23,42,0.08);
    }

    .category-icon {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        background: white;
        border: 1px solid #fde68a;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 23px;
        margin-bottom: 10px;
    }

    .category-name {
        font-size: 14px;
        font-weight: 800;
        text-align: center;
        line-height: 1.35;
        max-height: 38px;
        overflow: hidden;
    }

    .section-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 18px;
    }

    .section-title {
        font-size: 28px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 5px;
    }

    .section-subtitle {
        color: #6b7280;
        font-size: 16px;
        line-height: 1.5;
    }

    .section-link {
        text-decoration: none;
        color: #111827;
        background: #f3f4f6;
        border: 1px solid #e5e7eb;
        border-radius: 999px;
        padding: 10px 16px;
        font-size: 14px;
        font-weight: 800;
        white-space: nowrap;
        transition: 0.18s ease;
    }

    .section-link:hover {
        background: #111827;
        color: white;
    }

    .area-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .area-chip {
        text-decoration: none;
        color: #374151;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 999px;
        padding: 11px 16px;
        font-size: 15px;
        font-weight: 700;
        transition: 0.18s ease;
    }

    .area-chip:hover {
        background: #fffbea;
        border-color: #facc15;
        color: #111827;
        transform: translateY(-2px);
    }

    .post-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
    }

    .post-card {
        text-decoration: none;
        color: inherit;
        display: block;
        border: 1px solid #e5e7eb;
        border-radius: 22px;
        overflow: hidden;
        background: white;
        transition: 0.18s ease;
        height: 100%;
    }

    .post-card:hover {
        color: inherit;
        transform: translateY(-5px);
        box-shadow: 0 18px 36px rgba(15,23,42,0.13);
    }

    .post-image-wrap {
        height: 220px;
        background: #f3f4f6;
        position: relative;
        overflow: hidden;
    }

    .post-image-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: 0.24s ease;
    }

    .post-card:hover .post-image-wrap img {
        transform: scale(1.04);
    }

    .post-empty-image {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #9ca3af;
        font-size: 15px;
        font-weight: 700;
    }

    .vip-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        background: #ef4444;
        color: #fff;
        border-radius: 999px;
        padding: 7px 12px;
        font-size: 13px;
        font-weight: 800;
        box-shadow: 0 8px 20px rgba(239,68,68,0.26);
    }

    .date-badge {
        position: absolute;
        right: 12px;
        bottom: 12px;
        background: rgba(17,24,39,0.86);
        color: white;
        border-radius: 999px;
        padding: 6px 10px;
        font-size: 12px;
        font-weight: 700;
    }

    .post-body {
        padding: 16px;
    }

    .post-title {
        color: #111827;
        font-size: 17px;
        font-weight: 800;
        line-height: 1.42;
        min-height: 48px;
        margin-bottom: 10px;
        overflow: hidden;
    }

    .post-price {
        color: #ef4444;
        font-size: 23px;
        font-weight: 800;
        margin-bottom: 12px;
    }

    .post-meta {
        display: grid;
        gap: 5px;
        color: #6b7280;
        font-size: 14px;
        line-height: 1.45;
    }

    .empty-box {
        background: #f9fafb;
        border: 1px dashed #cbd5e1;
        border-radius: 20px;
        padding: 34px 20px;
        text-align: center;
        color: #6b7280;
        font-size: 16px;
        font-weight: 700;
    }

    @@media (max-width: 1200px) {
        .post-grid {
            grid-template-columns: repeat(3, 1fr);
        }

        .category-grid {
            grid-template-columns: repeat(4, 1fr);
        }

        .hero-title {
            font-size: 42px;
        }
    }

    @@media (max-width: 900px) {
        .search-grid {
            grid-template-columns: 1fr;
        }

        .post-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .section-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    @@media (max-width: 560px) {
        .category-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .post-grid {
            grid-template-columns: 1fr;
        }

        .hero-title {
            font-size: 32px;
        }

        .hero-subtitle {
            font-size: 16px;
        }

        .home-hero {
            padding-top: 34px;
        }
    }
</style>

<div class="home-page">
    <section class="home-hero">
        <div class="home-inner">
            <div class="hero-content">
                <div class="hero-badge">
                    <span>RV</span>
                    RaoVatWeb - Nền tảng rao vặt tổng hợp
                </div>

                <div class="hero-title">
                    Mua bán nhanh, tìm dễ, đăng tin tiện lợi
                </div>

                <div class="hero-subtitle">
                    Khám phá tin mua bán, trao đổi, cho thuê, dịch vụ và việc làm.
                    Thành viên VIP được ưu tiên hiển thị để tiếp cận người xem tốt hơn.
                </div>
            </div>
        </div>
    </section>

    <section class="search-panel">
        <div class="search-card">
            <form asp-controller="Home"
                  asp-action="Index"
                  method="get">

                <div class="search-grid">
                    <input name="keyword"
                           value="@Model.Keyword"
                           class="home-search-input"
                           placeholder="Tìm đồ cũ, dịch vụ, việc làm..." />

                    <select name="categoryId" class="home-search-select">
                        <option value="">Tất cả danh mục</option>

                        @foreach (var category in Model.Categories)
                        {
                            if (Model.CategoryId == category.CategoryId)
                            {
                                <option value="@category.CategoryId" selected>@category.Name</option>
                            }
                            else
                            {
                                <option value="@category.CategoryId">@category.Name</option>
                            }
                        }
                    </select>

                    <select name="areaId" class="home-search-select">
                        <option value="">Tất cả khu vực</option>

                        @foreach (var area in Model.Areas)
                        {
                            if (Model.AreaId == area.AreaId)
                            {
                                <option value="@area.AreaId" selected>@area.Name</option>
                            }
                            else
                            {
                                <option value="@area.AreaId">@area.Name</option>
                            }
                        }
                    </select>

                    <button type="submit" class="home-search-btn">
                        Tìm kiếm
                    </button>
                </div>
            </form>
        </div>
    </section>

    <section class="quick-section">
        <div class="quick-card">
            @if (Model.Categories.Any())
            {
                <div class="category-grid">
                    @foreach (var category in Model.Categories.Take(8))
                    {
                        <a asp-controller="Home"
                           asp-action="Index"
                           asp-route-categoryId="@category.CategoryId"
                           class="category-item">

                            <div class="category-icon">📦</div>
                            <div class="category-name">@category.Name</div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="empty-box">
                    Chưa có danh mục. Admin cần thêm danh mục trước.
                </div>
            }
        </div>
    </section>

    <section class="content-section">
        <div class="section-card">
            <div class="section-header">
                <div>
                    <div class="section-title">Khu vực phổ biến</div>
                    <div class="section-subtitle">
                        Lọc nhanh tin rao theo khu vực bạn quan tâm.
                    </div>
                </div>
            </div>

            @if (Model.Areas.Any())
            {
                <div class="area-row">
                    @foreach (var area in Model.Areas.Take(12))
                    {
                        <a asp-controller="Home"
                           asp-action="Index"
                           asp-route-areaId="@area.AreaId"
                           class="area-chip">
                            @area.Name
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="empty-box">
                    Chưa có khu vực. Admin cần thêm khu vực trước.
                </div>
            }
        </div>
    </section>

    @if (Model.VipPosts.Any())
    {
        <section class="content-section">
            <div class="section-card vip-section">
                <div class="section-header">
                    <div>
                        <div class="section-title">Tin VIP nổi bật</div>
                        <div class="section-subtitle">
                            Tin của thành viên VIP được đẩy lên vị trí ưu tiên.
                        </div>
                    </div>

                    <a asp-controller="VipPackages"
                       asp-action="Index"
                       class="section-link">
                        Nâng cấp VIP
                    </a>
                </div>

                <div class="post-grid">
                    @foreach (var item in Model.VipPosts)
                    {
                        <a asp-controller="Posts"
                           asp-action="Details"
                           asp-route-id="@item.PostId"
                           class="post-card">

                            <div class="post-image-wrap">
                                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Title" />
                                }
                                else
                                {
                                    <div class="post-empty-image">
                                        Chưa có hình ảnh
                                    </div>
                                }

                                <div class="vip-badge">VIP nổi bật</div>

                                <div class="date-badge">
                                    @item.CreatedAt.ToString("dd/MM")
                                </div>
                            </div>

                            <div class="post-body">
                                <div class="post-title">
                                    @item.Title
                                </div>

                                <div class="post-price">
                                    @item.Price.ToString("N0") đ
                                </div>

                                <div class="post-meta">
                                    <div>📍 @item.AreaName</div>
                                    <div>📂 @item.CategoryName</div>
                                    <div>👁 @item.ViewCount lượt xem</div>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </section>
    }

    <section class="content-section">
        <div class="section-card">
            <div class="section-header">
                <div>
                    <div class="section-title">Tin mới nhất</div>
                    <div class="section-subtitle">
                        Các tin đã được Admin duyệt và đang hiển thị công khai.
                    </div>
                </div>

                <a asp-controller="Posts"
                   asp-action="Index"
                   class="section-link">
                    Xem tất cả
                </a>
            </div>

            @if (!Model.LatestPosts.Any())
            {
                <div class="empty-box">
                    Chưa có tin đăng nào được duyệt. Hãy đăng tin và duyệt tin trong trang Admin để hiển thị tại đây.
                </div>
            }
            else
            {
                <div class="post-grid">
                    @foreach (var item in Model.LatestPosts)
                    {
                        <a asp-controller="Posts"
                           asp-action="Details"
                           asp-route-id="@item.PostId"
                           class="post-card">

                            <div class="post-image-wrap">
                                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Title" />
                                }
                                else
                                {
                                    <div class="post-empty-image">
                                        Chưa có hình ảnh
                                    </div>
                                }

                                @if (item.IsVipPriority)
                                {
                                    <div class="vip-badge">VIP</div>
                                }

                                <div class="date-badge">
                                    @item.CreatedAt.ToString("dd/MM")
                                </div>
                            </div>

                            <div class="post-body">
                                <div class="post-title">
                                    @item.Title
                                </div>

                                <div class="post-price">
                                    @item.Price.ToString("N0") đ
                                </div>

                                <div class="post-meta">
                                    <div>📍 @item.AreaName</div>
                                    <div>📂 @item.CategoryName</div>
                                    <div>👁 @item.ViewCount lượt xem</div>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </section>
</div>