@using RaoVatWeb.Models.Enums
@model IEnumerable<RaoVatWeb.Models.Post>

@{
    ViewData["Title"] = "Quản lý tin đăng";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Quản lý tin đăng</h2>

        <a asp-area="Admin"
           asp-controller="Dashboard"
           asp-action="Index"
           class="btn btn-secondary">
            Quay lại Dashboard
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <div class="mb-3">
        <a asp-area="Admin"
           asp-controller="Posts"
           asp-action="Index"
           class="btn btn-outline-dark">
            Tất cả
        </a>

        <a asp-area="Admin"
           asp-controller="Posts"
           asp-action="Index"
           asp-route-status="@PostStatus.Pending"
           class="btn btn-outline-warning">
            Chờ duyệt (@ViewBag.PendingCount)
        </a>

        <a asp-area="Admin"
           asp-controller="Posts"
           asp-action="Index"
           asp-route-status="@PostStatus.Approved"
           class="btn btn-outline-success">
            Đã duyệt (@ViewBag.ApprovedCount)
        </a>

        <a asp-area="Admin"
           asp-controller="Posts"
           asp-action="Index"
           asp-route-status="@PostStatus.Rejected"
           class="btn btn-outline-danger">
            Bị từ chối (@ViewBag.RejectedCount)
        </a>

        <a asp-area="Admin"
           asp-controller="Posts"
           asp-action="Index"
           asp-route-status="@PostStatus.Hidden"
           class="btn btn-outline-secondary">
            Đã ẩn (@ViewBag.HiddenCount)
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Chưa có tin đăng nào.
        </div>
    }
    else
    {
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Tiêu đề</th>
                    <th>Danh mục</th>
                    <th>Khu vực</th>
                    <th>Giá</th>
                    <th>Liên hệ</th>
                    <th>Trạng thái</th>
                    <th>Ngày đăng</th>
                    <th style="width: 260px;">Thao tác</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.PostId</td>

                        <td>
                            <strong>@item.Title</strong>
                            <br />
                            <small class="text-muted">
                                @item.Description
                            </small>
                        </td>

                        <td>
                            @(item.Category != null ? item.Category.Name : "Chưa có")
                        </td>

                        <td>
                            @(item.Area != null ? item.Area.Name : "Chưa có")
                        </td>

                        <td>
                            @string.Format("{0:N0} VNĐ", item.Price)
                        </td>

                        <td>
                            @item.ContactName
                            <br />
                            <small>@item.ContactPhone</small>
                        </td>

                        <td>
                            @if (item.Status == PostStatus.Pending)
                        {
                                <span class="badge bg-warning text-dark">Chờ duyệt</span>
                        }
                            else if (item.Status == PostStatus.Approved)
                        {   
                                <span class="badge bg-success">Đã duyệt</span>
                        }
                            else if (item.Status == PostStatus.Rejected)
                        {
                                <span class="badge bg-danger">Bị từ chối</span>
                        }
                            else if (item.Status == PostStatus.Hidden)
                        {
                                <span class="badge bg-secondary">Đã ẩn</span>
                        }   
                        </td>

                        <td>
                            @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                        </td>

                        <td>
                            @if (item.Status != PostStatus.Approved)
                            {
                                <form asp-area="Admin"
                                      asp-controller="Posts"
                                      asp-action="Approve"
                                      asp-route-id="@item.PostId"
                                      method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()

                                    <button type="submit" class="btn btn-sm btn-success">
                                        Duyệt
                                    </button>
                                </form>
                            }

                            @if (item.Status != PostStatus.Rejected)
                            {
                                <form asp-area="Admin"
                                      asp-controller="Posts"
                                      asp-action="Reject"
                                      asp-route-id="@item.PostId"
                                      method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()

                                    <button type="submit" class="btn btn-sm btn-danger">
                                        Từ chối
                                    </button>
                                </form>
                            }

                            @if (item.Status != PostStatus.Hidden)
                            {
                                <form asp-area="Admin"
                                      asp-controller="Posts"
                                      asp-action="Hide"
                                      asp-route-id="@item.PostId"
                                      method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()

                                    <button type="submit" class="btn btn-sm btn-secondary">
                                        Ẩn
                                    </button>
                                </form>
                            }

                            @if (item.Status != PostStatus.Pending)
                            {
                                <form asp-area="Admin"
                                      asp-controller="Posts"
                                      asp-action="RestoreToPending"
                                      asp-route-id="@item.PostId"
                                      method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()

                                    <button type="submit" class="btn btn-sm btn-warning">
                                        Chờ duyệt
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>