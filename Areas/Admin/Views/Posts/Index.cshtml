@using RaoVatWeb.Models.Enums
@model IEnumerable<RaoVatWeb.Models.Post>

@{
    ViewData["Title"] = "Quản lý tin đăng";

    var posts = Model != null
        ? Model.ToList()
        : new List<RaoVatWeb.Models.Post>();

    PostStatus? currentStatus = ViewBag.Status as PostStatus?;

    var totalPosts = posts.Count;
    var pendingCount = posts.Count(x => x.Status == PostStatus.Pending);
    var approvedCount = posts.Count(x => x.Status == PostStatus.Approved);
    var rejectedCount = posts.Count(x => x.Status == PostStatus.Rejected);
    var hiddenCount = posts.Count(x => x.Status == PostStatus.Hidden);
}

<style>
    body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    }

    .admin-posts-page {
        background: #f4f5f7;
        min-height: 100vh;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        margin-top: -24px;
        padding: 34px 0 56px;
    }

    .admin-posts-container {
        max-width: 1360px;
        width: 94vw;
        margin: 0 auto;
    }

    .admin-hero {
        background: linear-gradient(135deg, #111827, #020617);
        color: white;
        border-radius: 34px;
        padding: 38px;
        margin-bottom: 24px;
        box-shadow: 0 22px 52px rgba(15,23,42,0.18);
        position: relative;
        overflow: hidden;
    }

    .admin-hero::after {
        content: "";
        position: absolute;
        right: -90px;
        bottom: -110px;
        width: 320px;
        height: 320px;
        border-radius: 999px;
        background: rgba(255,212,59,0.18);
    }

    .hero-content {
        position: relative;
        z-index: 2;
        display: flex;
        justify-content: space-between;
        gap: 22px;
        align-items: center;
    }

    .admin-badge {
        display: inline-flex;
        background: rgba(255,212,59,0.14);
        border: 1px solid rgba(255,212,59,0.38);
        color: #ffd43b;
        border-radius: 999px;
        padding: 9px 15px;
        font-weight: 900;
        margin-bottom: 14px;
    }

    .hero-title {
        font-size: 44px;
        font-weight: 900;
        line-height: 1.15;
        margin-bottom: 10px;
    }

    .hero-subtitle {
        color: #d1d5db;
        font-size: 18px;
        line-height: 1.65;
        max-width: 780px;
        margin: 0;
    }

    .hero-action {
        height: 54px;
        border-radius: 18px;
        background: #ffd43b;
        color: #111827;
        border: 1px solid #f2b705;
        padding: 0 22px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 16px;
        font-weight: 900;
        white-space: nowrap;
    }

    .hero-action:hover {
        background: #facc15;
        color: #111827;
    }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .stat-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        padding: 20px;
        box-shadow: 0 12px 30px rgba(15,23,42,0.07);
    }

    .stat-label {
        color: #6b7280;
        font-size: 14px;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .stat-value {
        color: #111827;
        font-size: 32px;
        font-weight: 900;
        line-height: 1.1;
    }

    .filter-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 28px;
        padding: 22px;
        margin-bottom: 24px;
        box-shadow: 0 12px 30px rgba(15,23,42,0.07);
    }

    .filter-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .filter-chip {
        height: 46px;
        border-radius: 999px;
        border: 1px solid #e5e7eb;
        background: #f8fafc;
        color: #374151;
        padding: 0 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 15px;
        font-weight: 850;
    }

    .filter-chip:hover {
        background: #fffbea;
        border-color: #facc15;
        color: #111827;
    }

    .filter-chip.active {
        background: #111827;
        border-color: #111827;
        color: white;
    }

    .posts-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 30px;
        padding: 26px;
        box-shadow: 0 14px 34px rgba(15,23,42,0.08);
    }

    .card-head {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-end;
        margin-bottom: 22px;
    }

    .card-title {
        color: #111827;
        font-size: 30px;
        font-weight: 900;
        margin-bottom: 6px;
    }

    .card-subtitle {
        color: #6b7280;
        font-size: 16px;
        line-height: 1.55;
    }

    .post-count {
        background: #fffbea;
        border: 1px solid #facc15;
        color: #92400e;
        border-radius: 999px;
        padding: 9px 15px;
        font-size: 14px;
        font-weight: 900;
        white-space: nowrap;
    }

    .admin-post-list {
        display: grid;
        gap: 16px;
    }

    .admin-post-item {
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        background: #fff;
        padding: 18px;
        display: grid;
        grid-template-columns: 150px 1fr 220px;
        gap: 18px;
        transition: 0.18s ease;
    }

    .admin-post-item:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 34px rgba(15,23,42,0.09);
    }

    .post-image {
        width: 150px;
        height: 120px;
        border-radius: 18px;
        overflow: hidden;
        background: #f3f4f6;
        border: 1px solid #e5e7eb;
    }

    .post-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .post-no-image {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
        color: #9ca3af;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        font-size: 13px;
        font-weight: 800;
        padding: 10px;
    }

    .post-top {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: center;
        margin-bottom: 10px;
    }

    .status-badge,
    .vip-badge {
        border-radius: 999px;
        padding: 7px 12px;
        font-size: 13px;
        font-weight: 900;
        border: 1px solid transparent;
        white-space: nowrap;
    }

    .status-pending {
        background: #fff7ed;
        color: #9a3412;
        border-color: #fed7aa;
    }

    .status-approved {
        background: #ecfdf5;
        color: #047857;
        border-color: #a7f3d0;
    }

    .status-rejected {
        background: #fef2f2;
        color: #b91c1c;
        border-color: #fecaca;
    }

    .status-hidden {
        background: #f3f4f6;
        color: #374151;
        border-color: #d1d5db;
    }

    .vip-badge {
        background: #ef4444;
        color: white;
        border-color: #ef4444;
    }

    .post-title {
        color: #111827;
        font-size: 22px;
        line-height: 1.35;
        font-weight: 900;
        margin-bottom: 8px;
    }

    .post-price {
        color: #ef4444;
        font-size: 24px;
        font-weight: 900;
        margin-bottom: 10px;
    }

    .post-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 13px;
        color: #6b7280;
        font-size: 14px;
        font-weight: 650;
        line-height: 1.5;
    }

    .action-box {
        display: grid;
        gap: 10px;
        align-content: start;
    }

    .action-link,
    .action-btn {
        height: 42px;
        border-radius: 14px;
        border: none;
        width: 100%;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 900;
        cursor: pointer;
    }

    .btn-detail {
        background: #f3f4f6;
        color: #111827;
        border: 1px solid #e5e7eb;
    }

    .btn-detail:hover {
        background: #e5e7eb;
        color: #111827;
    }

    .btn-approve {
        background: #16a34a;
        color: white;
    }

    .btn-approve:hover {
        background: #15803d;
        color: white;
    }

    .btn-reject {
        background: #ef4444;
        color: white;
    }

    .btn-reject:hover {
        background: #dc2626;
        color: white;
    }

    .btn-hide {
        background: #111827;
        color: white;
    }

    .btn-hide:hover {
        background: #000;
        color: white;
    }

    .btn-restore {
        background: #ffd43b;
        color: #111827;
        border: 1px solid #f2b705;
    }

    .btn-restore:hover {
        background: #facc15;
        color: #111827;
    }

    .empty-box {
        background: #f9fafb;
        border: 1px dashed #cbd5e1;
        border-radius: 24px;
        padding: 46px 24px;
        text-align: center;
        color: #6b7280;
        font-size: 17px;
        font-weight: 750;
    }

    .empty-box strong {
        color: #111827;
        font-size: 23px;
        display: block;
        margin-bottom: 8px;
    }

    @@media (max-width: 1150px) {
        .stat-grid {
            grid-template-columns: repeat(3, 1fr);
        }

        .admin-post-item {
            grid-template-columns: 130px 1fr;
        }

        .action-box {
            grid-column: 1 / -1;
            grid-template-columns: repeat(4, 1fr);
        }

        .post-image {
            width: 130px;
            height: 110px;
        }

        .hero-content {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    @@media (max-width: 720px) {
        .stat-grid {
            grid-template-columns: 1fr;
        }

        .admin-post-item {
            grid-template-columns: 1fr;
        }

        .post-image {
            width: 100%;
            height: 220px;
        }

        .action-box {
            grid-template-columns: 1fr;
        }

        .admin-hero,
        .posts-card,
        .filter-card {
            padding: 22px;
        }

        .hero-title {
            font-size: 33px;
        }

        .card-head {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<div class="admin-posts-page">
    <div class="admin-posts-container">
        <div class="admin-hero">
            <div class="hero-content">
                <div>
                    <div class="admin-badge">
                        📢 Quản trị tin rao vặt
                    </div>

                    <div class="hero-title">
                        Duyệt và quản lý tin đăng
                    </div>

                    <p class="hero-subtitle">
                        Admin kiểm tra nội dung tin rao, duyệt tin hợp lệ, từ chối tin sai quy định hoặc ẩn tin vi phạm khỏi website.
                    </p>
                </div>

                <a asp-area="Admin"
                   asp-controller="Dashboard"
                   asp-action="Index"
                   class="hero-action">
                    Về Dashboard
                </a>
            </div>
        </div>

        <div class="stat-grid">
            <div class="stat-card">
                <div class="stat-label">Tổng tin</div>
                <div class="stat-value">@totalPosts</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Chờ duyệt</div>
                <div class="stat-value">@pendingCount</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Đã duyệt</div>
                <div class="stat-value">@approvedCount</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Bị từ chối</div>
                <div class="stat-value">@rejectedCount</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Đã ẩn</div>
                <div class="stat-value">@hiddenCount</div>
            </div>
        </div>

        <div class="filter-card">
            <div class="filter-row">
                <a asp-area="Admin"
                   asp-controller="Posts"
                   asp-action="Index"
                   class="filter-chip @(currentStatus == null ? "active" : "")">
                    Tất cả
                </a>

                <a asp-area="Admin"
                   asp-controller="Posts"
                   asp-action="Index"
                   asp-route-status="@PostStatus.Pending"
                   class="filter-chip @(currentStatus == PostStatus.Pending ? "active" : "")">
                    Chờ duyệt
                </a>

                <a asp-area="Admin"
                   asp-controller="Posts"
                   asp-action="Index"
                   asp-route-status="@PostStatus.Approved"
                   class="filter-chip @(currentStatus == PostStatus.Approved ? "active" : "")">
                    Đã duyệt
                </a>

                <a asp-area="Admin"
                   asp-controller="Posts"
                   asp-action="Index"
                   asp-route-status="@PostStatus.Rejected"
                   class="filter-chip @(currentStatus == PostStatus.Rejected ? "active" : "")">
                    Bị từ chối
                </a>

                <a asp-area="Admin"
                   asp-controller="Posts"
                   asp-action="Index"
                   asp-route-status="@PostStatus.Hidden"
                   class="filter-chip @(currentStatus == PostStatus.Hidden ? "active" : "")">
                    Đã ẩn
                </a>
            </div>
        </div>

        <div class="posts-card">
            <div class="card-head">
                <div>
                    <div class="card-title">
                        Danh sách tin đăng
                    </div>

                    <div class="card-subtitle">
                        Tin mới nhất được hiển thị phía trên. Admin có thể thao tác trực tiếp trên từng tin.
                    </div>
                </div>

                <div class="post-count">
                    @posts.Count tin
                </div>
            </div>

            @if (!posts.Any())
            {
                <div class="empty-box">
                    <strong>Không có tin đăng nào.</strong>
                    Hiện chưa có tin phù hợp với bộ lọc đang chọn.
                </div>
            }
            else
            {
                <div class="admin-post-list">
                    @foreach (var post in posts)
                    {
                        var image = post.Images != null
                            ? post.Images
                                .OrderByDescending(x => x.IsMainImage)
                                .ThenBy(x => x.PostImageId)
                                .FirstOrDefault()
                            : null;

                        string statusClass = "status-pending";
                        string statusText = "Chờ duyệt";

                        if (post.Status == PostStatus.Approved)
                        {
                            statusClass = "status-approved";
                            statusText = "Đã duyệt";
                        }
                        else if (post.Status == PostStatus.Rejected)
                        {
                            statusClass = "status-rejected";
                            statusText = "Bị từ chối";
                        }
                        else if (post.Status == PostStatus.Hidden)
                        {
                            statusClass = "status-hidden";
                            statusText = "Đã ẩn";
                        }

                        <div class="admin-post-item">
                            <div class="post-image">
                                @if (image != null && !string.IsNullOrWhiteSpace(image.ImageUrl))
                                {
                                    <img src="@image.ImageUrl" alt="@post.Title" />
                                }
                                else
                                {
                                    <div class="post-no-image">
                                        Chưa có hình
                                    </div>
                                }
                            </div>

                            <div>
                                <div class="post-top">
                                    <span class="status-badge @statusClass">
                                        @statusText
                                    </span>

                                    @if (post.IsVipPriority)
                                    {
                                        <span class="vip-badge">
                                            VIP nổi bật
                                        </span>
                                    }
                                </div>

                                <div class="post-title">
                                    @post.Title
                                </div>

                                <div class="post-price">
                                    @post.Price.ToString("N0") đ
                                </div>

                                <div class="post-meta">
                                    <span>📂 @(post.Category != null ? post.Category.Name : "Chưa có danh mục")</span>
                                    <span>📍 @(post.Area != null ? post.Area.Name : "Chưa có khu vực")</span>
                                    <span>👁 @post.ViewCount lượt xem</span>
                                    <span>🕒 @post.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                            </div>

                            <div class="action-box">
                                <a asp-area="Admin"
                                   asp-controller="Posts"
                                   asp-action="Details"
                                   asp-route-id="@post.PostId"
                                   class="action-link btn-detail">
                                    Xem chi tiết
                                </a>

                                @if (post.Status != PostStatus.Approved)
                                {
                                    <form asp-area="Admin"
                                          asp-controller="Posts"
                                          asp-action="Approve"
                                          asp-route-id="@post.PostId"
                                          method="post"
                                          asp-antiforgery="true">
                                        <button type="submit"
                                                class="action-btn btn-approve"
                                                onclick="return confirm('Duyệt tin này để hiển thị công khai?');">
                                            Duyệt tin
                                        </button>
                                    </form>
                                }

                                @if (post.Status != PostStatus.Rejected)
                                {
                                    <form asp-area="Admin"
                                          asp-controller="Posts"
                                          asp-action="Reject"
                                          asp-route-id="@post.PostId"
                                          method="post"
                                          asp-antiforgery="true">
                                        <button type="submit"
                                                class="action-btn btn-reject"
                                                onclick="return confirm('Từ chối tin đăng này?');">
                                            Từ chối
                                        </button>
                                    </form>
                                }

                                @if (post.Status != PostStatus.Hidden)
                                {
                                    <form asp-area="Admin"
                                          asp-controller="Posts"
                                          asp-action="Hide"
                                          asp-route-id="@post.PostId"
                                          method="post"
                                          asp-antiforgery="true">
                                        <button type="submit"
                                                class="action-btn btn-hide"
                                                onclick="return confirm('Ẩn tin này khỏi website?');">
                                            Ẩn tin
                                        </button>
                                    </form>
                                }

                                @if (post.Status == PostStatus.Rejected || post.Status == PostStatus.Hidden)
                                {
                                    <form asp-area="Admin"
                                          asp-controller="Posts"
                                          asp-action="RestoreToPending"
                                          asp-route-id="@post.PostId"
                                          method="post"
                                          asp-antiforgery="true">
                                        <button type="submit"
                                                class="action-btn btn-restore"
                                                onclick="return confirm('Chuyển tin về trạng thái chờ duyệt?');">
                                            Chờ duyệt
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>