@model IEnumerable<RaoVatWeb.Models.Area>

@{
    ViewData["Title"] = "Quản lý khu vực";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Quản lý khu vực</h2>

        <a asp-area="Admin"
           asp-controller="Areas"
           asp-action="Create"
           class="btn btn-primary">
            Thêm khu vực
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tên khu vực</th>
                <th>Khu vực cha</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.AreaId</td>

                    <td>@item.Name</td>

                    <td>
                        @(item.ParentArea != null ? item.ParentArea.Name : "Không có")
                    </td>

                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge bg-success">Đang hiển thị</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Đã ẩn</span>
                        }
                    </td>

                    <td>
                        <a asp-area="Admin"
                           asp-controller="Areas"
                           asp-action="Edit"
                           asp-route-id="@item.AreaId"
                           class="btn btn-sm btn-warning">
                            Sửa
                        </a>

                        <form asp-area="Admin"
                              asp-controller="Areas"
                              asp-action="ToggleStatus"
                              asp-route-id="@item.AreaId"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()

                            @if (item.IsActive)
                            {
                                <button type="submit" class="btn btn-sm btn-secondary">
                                    Ẩn
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-sm btn-success">
                                    Khôi phục
                                </button>
                            }
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-area="Admin"
       asp-controller="Dashboard"
       asp-action="Index"
       class="btn btn-secondary">
        Quay lại Dashboard
    </a>
</div>