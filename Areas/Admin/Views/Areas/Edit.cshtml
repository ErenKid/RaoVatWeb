@model RaoVatWeb.ViewModels.AdminAreaFormViewModel

@{
    ViewData["Title"] = "Sửa khu vực";
}

<div class="container mt-4">
    <h2>Sửa khu vực</h2>

    <form asp-area="Admin"
          asp-controller="Areas"
          asp-action="Edit"
          asp-route-id="@Model.AreaId"
          method="post">

        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="AreaId" />

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label">Tên khu vực</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ParentAreaId" class="form-label">Khu vực cha</label>

            <select asp-for="ParentAreaId"
                    asp-items="@(ViewBag.ParentAreaId as SelectList)"
                    class="form-select">
                <option value="">-- Không chọn nếu là khu vực cha --</option>
            </select>
        </div>

        <div class="form-check mb-3">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label">
                Hiển thị khu vực
            </label>
        </div>

        <button type="submit" class="btn btn-primary">
            Cập nhật
        </button>

        <a asp-area="Admin"
           asp-controller="Areas"
           asp-action="Index"
           class="btn btn-secondary">
            Quay lại
        </a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}