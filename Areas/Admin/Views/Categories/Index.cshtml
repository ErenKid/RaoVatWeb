@model IEnumerable<RaoVatWeb.Models.Category>

@{
    ViewData["Title"] = "Quản lý danh mục";

    var categories = Model != null
        ? Model.ToList()
        : new List<RaoVatWeb.Models.Category>();

    var activeCount = categories.Count(x => x.IsActive);
    var inactiveCount = categories.Count(x => !x.IsActive);
}

<style>
    body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    }

    .category-page {
        background: #f4f5f7;
        min-height: 100vh;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        margin-top: -24px;
        padding: 34px 0 56px;
    }

    .category-container {
        max-width: 1320px;
        width: 94vw;
        margin: 0 auto;
    }

    .category-hero {
        background: linear-gradient(135deg, #111827, #020617);
        color: white;
        border-radius: 34px;
        padding: 38px;
        margin-bottom: 24px;
        box-shadow: 0 22px 52px rgba(15,23,42,0.18);
        position: relative;
        overflow: hidden;
    }

    .category-hero::after {
        content: "";
        position: absolute;
        right: -90px;
        bottom: -110px;
        width: 320px;
        height: 320px;
        border-radius: 999px;
        background: rgba(255,212,59,0.18);
    }

    .hero-content {
        position: relative;
        z-index: 2;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 22px;
    }

    .hero-badge {
        display: inline-flex;
        background: rgba(255,212,59,0.14);
        border: 1px solid rgba(255,212,59,0.38);
        color: #ffd43b;
        border-radius: 999px;
        padding: 9px 15px;
        font-weight: 900;
        margin-bottom: 14px;
    }

    .hero-title {
        font-size: 44px;
        font-weight: 900;
        line-height: 1.15;
        margin-bottom: 10px;
    }

    .hero-subtitle {
        color: #d1d5db;
        font-size: 18px;
        line-height: 1.65;
        max-width: 780px;
        margin: 0;
    }

    .hero-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .hero-btn {
        height: 54px;
        border-radius: 18px;
        background: #ffd43b;
        color: #111827;
        border: 1px solid #f2b705;
        padding: 0 22px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-size: 16px;
        font-weight: 900;
        white-space: nowrap;
    }

    .hero-btn:hover {
        background: #facc15;
        color: #111827;
    }

    .hero-btn-dark {
        background: rgba(255,255,255,0.08);
        color: white;
        border: 1px solid rgba(255,255,255,0.18);
    }

    .hero-btn-dark:hover {
        background: rgba(255,255,255,0.14);
        color: white;
    }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .stat-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 26px;
        padding: 22px;
        box-shadow: 0 12px 30px rgba(15,23,42,0.07);
        position: relative;
        overflow: hidden;
    }

    .stat-card::after {
        content: "";
        position: absolute;
        right: -34px;
        bottom: -42px;
        width: 120px;
        height: 120px;
        border-radius: 999px;
        background: #fffbea;
    }

    .stat-content {
        position: relative;
        z-index: 2;
    }

    .stat-icon {
        width: 46px;
        height: 46px;
        border-radius: 17px;
        background: #111827;
        color: #ffd43b;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        margin-bottom: 12px;
    }

    .stat-label {
        color: #6b7280;
        font-size: 15px;
        font-weight: 800;
        margin-bottom: 6px;
    }

    .stat-value {
        color: #111827;
        font-size: 34px;
        font-weight: 900;
        line-height: 1;
    }

    .category-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 30px;
        padding: 26px;
        box-shadow: 0 14px 34px rgba(15,23,42,0.08);
    }

    .card-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 16px;
        margin-bottom: 22px;
    }

    .card-title {
        color: #111827;
        font-size: 30px;
        font-weight: 900;
        margin-bottom: 6px;
    }

    .card-subtitle {
        color: #6b7280;
        font-size: 16px;
        line-height: 1.55;
    }

    .category-count {
        background: #fffbea;
        border: 1px solid #facc15;
        color: #92400e;
        border-radius: 999px;
        padding: 9px 15px;
        font-size: 14px;
        font-weight: 900;
        white-space: nowrap;
    }

    .category-list {
        display: grid;
        gap: 16px;
    }

    .category-item {
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        background: #fff;
        padding: 20px;
        display: grid;
        grid-template-columns: 70px 1fr 220px;
        gap: 18px;
        align-items: center;
        transition: 0.18s ease;
    }

    .category-item:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 34px rgba(15,23,42,0.09);
    }

    .category-icon {
        width: 70px;
        height: 70px;
        border-radius: 24px;
        background: #111827;
        color: #ffd43b;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        font-weight: 900;
    }

    .category-name-row {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 8px;
    }

    .category-name {
        color: #111827;
        font-size: 23px;
        line-height: 1.3;
        font-weight: 900;
    }

    .status-badge {
        border-radius: 999px;
        padding: 7px 12px;
        font-size: 13px;
        font-weight: 900;
        border: 1px solid transparent;
        white-space: nowrap;
    }

    .status-active {
        background: #ecfdf5;
        color: #047857;
        border-color: #a7f3d0;
    }

    .status-inactive {
        background: #f3f4f6;
        color: #374151;
        border-color: #d1d5db;
    }

    .category-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        color: #6b7280;
        font-size: 14px;
        font-weight: 650;
        line-height: 1.5;
    }

    .id-pill {
        color: #374151;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 999px;
        padding: 6px 10px;
        font-weight: 850;
    }

    .post-count-pill {
        color: #92400e;
        background: #fffbea;
        border: 1px solid #facc15;
        border-radius: 999px;
        padding: 6px 10px;
        font-weight: 850;
    }

    .action-box {
        display: grid;
        gap: 10px;
    }

    .action-link,
    .action-btn {
        height: 42px;
        border-radius: 14px;
        border: none;
        width: 100%;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 900;
        cursor: pointer;
    }

    .btn-edit {
        background: #ffd43b;
        color: #111827;
        border: 1px solid #f2b705;
    }

    .btn-edit:hover {
        background: #facc15;
        color: #111827;
    }

    .btn-delete {
        background: #ef4444;
        color: white;
    }

    .btn-delete:hover {
        background: #dc2626;
        color: white;
    }

    .btn-detail {
        background: #f3f4f6;
        color: #111827;
        border: 1px solid #e5e7eb;
    }

    .btn-detail:hover {
        background: #e5e7eb;
        color: #111827;
    }

    .empty-box {
        background: #f9fafb;
        border: 1px dashed #cbd5e1;
        border-radius: 24px;
        padding: 46px 24px;
        text-align: center;
        color: #6b7280;
        font-size: 17px;
        font-weight: 750;
    }

    .empty-box strong {
        color: #111827;
        font-size: 23px;
        display: block;
        margin-bottom: 8px;
    }

    @@media (max-width: 1050px) {
        .stat-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .hero-content {
            flex-direction: column;
            align-items: flex-start;
        }

        .hero-actions {
            justify-content: flex-start;
        }

        .category-item {
            grid-template-columns: 70px 1fr;
        }

        .action-box {
            grid-column: 1 / -1;
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 640px) {
        .stat-grid {
            grid-template-columns: 1fr;
        }

        .category-item {
            grid-template-columns: 1fr;
        }

        .action-box {
            grid-template-columns: 1fr;
        }

        .hero-title {
            font-size: 33px;
        }

        .category-hero,
        .category-card {
            padding: 22px;
        }

        .card-head {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<div class="category-page">
    <div class="category-container">
        <div class="category-hero">
            <div class="hero-content">
                <div>
                    <div class="hero-badge">
                        📂 Quản trị danh mục
                    </div>

                    <div class="hero-title">
                        Quản lý danh mục tin rao
                    </div>

                    <p class="hero-subtitle">
                        Danh mục giúp phân loại tin mua bán, trao đổi, cho thuê, dịch vụ, việc làm
                        và các nhóm rao vặt khác trên hệ thống.
                    </p>
                </div>

                <div class="hero-actions">
                    <a asp-area="Admin"
                       asp-controller="Dashboard"
                       asp-action="Index"
                       class="hero-btn hero-btn-dark">
                        Về Dashboard
                    </a>

                    <a asp-area="Admin"
                       asp-controller="Categories"
                       asp-action="Create"
                       class="hero-btn">
                        + Thêm danh mục
                    </a>
                </div>
            </div>
        </div>

        <div class="stat-grid">
            <div class="stat-card">
                <div class="stat-content">
                    <div class="stat-icon">📂</div>
                    <div class="stat-label">Tổng danh mục</div>
                    <div class="stat-value">@categories.Count</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-content">
                    <div class="stat-icon">✅</div>
                    <div class="stat-label">Đang hoạt động</div>
                    <div class="stat-value">@activeCount</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-content">
                    <div class="stat-icon">⏸</div>
                    <div class="stat-label">Đang tắt</div>
                    <div class="stat-value">@inactiveCount</div>
                </div>
            </div>
        </div>

        <div class="category-card">
            <div class="card-head">
                <div>
                    <div class="card-title">
                        Danh sách danh mục
                    </div>

                    <div class="card-subtitle">
                        Admin có thể thêm, sửa hoặc xóa danh mục để điều chỉnh cấu trúc tin rao trên website.
                    </div>
                </div>

                <div class="category-count">
                    @categories.Count danh mục
                </div>
            </div>

            @if (!categories.Any())
            {
                <div class="empty-box">
                    <strong>Chưa có danh mục nào.</strong>
                    Hãy thêm danh mục đầu tiên để người dùng có thể đăng tin.
                </div>
            }
            else
            {
                <div class="category-list">
                    @foreach (var category in categories)
                    {
                        var postCount = category.Posts != null
                            ? category.Posts.Count
                            : 0;

                        <div class="category-item">
                            <div class="category-icon">
                                📂
                            </div>

                            <div>
                                <div class="category-name-row">
                                    <div class="category-name">
                                        @category.Name
                                    </div>

                                    @if (category.IsActive)
                                    {
                                        <span class="status-badge status-active">
                                            Đang hoạt động
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-inactive">
                                            Đã tắt
                                        </span>
                                    }
                                </div>

                                <div class="category-meta">
                                    <span class="id-pill">
                                        ID: @category.CategoryId
                                    </span>

                                    <span class="post-count-pill">
                                        📢 @postCount tin đăng
                                    </span>
                                </div>
                            </div>

                            <div class="action-box">
                                <a asp-area="Admin"
                                   asp-controller="Categories"
                                   asp-action="Details"
                                   asp-route-id="@category.CategoryId"
                                   class="action-link btn-detail">
                                    Chi tiết
                                </a>

                                <a asp-area="Admin"
                                   asp-controller="Categories"
                                   asp-action="Edit"
                                   asp-route-id="@category.CategoryId"
                                   class="action-link btn-edit">
                                    Sửa
                                </a>

                                <form asp-area="Admin"
                                      asp-controller="Categories"
                                      asp-action="Delete"
                                      asp-route-id="@category.CategoryId"
                                      method="post"
                                      asp-antiforgery="true">

                                    <button type="submit"
                                            class="action-btn btn-delete"
                                            onclick="return confirm('Bạn có chắc muốn xóa danh mục này không?');">
                                        Xóa
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>