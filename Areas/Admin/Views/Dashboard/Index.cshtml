@using RaoVatWeb.Models.Enums
@model RaoVatWeb.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Dashboard Admin";
}

        <div class="container mt-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Dashboard quản trị</h2>

            <a asp-area="Admin"
            asp-controller="Users"
            asp-action="Index"
            class="btn btn-outline-primary">
                Quản lý người dùng
            </a>
        </div>

    <div class="row">
        <div class="col-md-3 mb-3">
            <div class="card text-bg-primary">
                <div class="card-body">
                    <h6>Tổng tin đăng</h6>
                    <h2>@Model.TotalPosts</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card text-bg-warning">
                <div class="card-body">
                    <h6>Tin chờ duyệt</h6>
                    <h2>@Model.PendingPosts</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card text-bg-success">
                <div class="card-body">
                    <h6>Tin đã duyệt</h6>
                    <h2>@Model.ApprovedPosts</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card text-bg-danger">
                <div class="card-body">
                    <h6>Tin bị từ chối</h6>
                    <h2>@Model.RejectedPosts</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card text-bg-secondary">
                <div class="card-body">
                    <h6>Tin đã ẩn</h6>
                    <h2>@Model.HiddenPosts</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card text-bg-info">
                <div class="card-body">
                    <h6>Tổng người dùng</h6>
                    <h2>@Model.TotalUsers</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card text-bg-dark">
                <div class="card-body">
                    <h6>Tổng hình ảnh tin đăng</h6>
                    <h2>@Model.TotalImages</h2>
                </div>
            </div>
        </div>
    </div>

    <hr />

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Tin mới đăng gần đây</h4>

        <a asp-area="Admin"
           asp-controller="Posts"
           asp-action="Index"
           class="btn btn-outline-primary">
            Xem tất cả tin đăng
        </a>
    </div>

    @if (Model.RecentPosts == null || Model.RecentPosts.Count == 0)
    {
        <div class="alert alert-info">
            Chưa có tin đăng nào trong hệ thống.
        </div>
    }
    else
    {
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Tiêu đề</th>
                    <th>Danh mục</th>
                    <th>Khu vực</th>
                    <th>Giá</th>
                    <th>Trạng thái</th>
                    <th>Ngày đăng</th>
                    <th style="width: 120px;">Thao tác</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.RecentPosts)
                {
                    <tr>
                        <td>@item.Title</td>

                        <td>
                            @(item.Category != null ? item.Category.Name : "Chưa có")
                        </td>

                        <td>
                            @(item.Area != null ? item.Area.Name : "Chưa có")
                        </td>

                        <td>
                            @string.Format("{0:N0} VNĐ", item.Price)
                        </td>

                        <td>
                            @if (item.Status == PostStatus.Pending)
                            {
                                <span class="badge bg-warning text-dark">Chờ duyệt</span>
                            }
                            else if (item.Status == PostStatus.Approved)
                            {
                                <span class="badge bg-success">Đã duyệt</span>
                            }
                            else if (item.Status == PostStatus.Rejected)
                            {
                                <span class="badge bg-danger">Bị từ chối</span>
                            }
                            else if (item.Status == PostStatus.Hidden)
                            {
                                <span class="badge bg-secondary">Đã ẩn</span>
                            }
                        </td>

                        <td>
                            @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                        </td>

                        <td>
                            <a asp-area="Admin"
                               asp-controller="Posts"
                               asp-action="Details"
                               asp-route-id="@item.PostId"
                               class="btn btn-sm btn-primary">
                                Chi tiết
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>